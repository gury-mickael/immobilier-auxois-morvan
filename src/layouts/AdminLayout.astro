---
interface Props {
  title: string;
  description?: string;
  adminName?: string;
  currentPath?: string;
}

const { title, description = 'Administration du site', adminName, currentPath = Astro.url.pathname } = Astro.props;

const navigation = [
  { href: '/admin', label: 'Tableau de bord' },
  { href: '/admin/pages', label: 'Pages' },
  { href: '/admin/local-pages', label: 'Pages locales' },
  { href: '/admin/blog', label: 'Blog' },
  { href: '/admin/media', label: 'Médias' },
  { href: '/admin/settings', label: 'Paramètres' }
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} | Admin</title>
    <style>
      :root {
        --admin-bg: #f5f1ea;
        --admin-panel: #ffffff;
        --admin-panel-soft: #f8fbfd;
        --admin-text: #1a2530;
        --admin-muted: #6a7682;
        --admin-border: #d9e1e7;
        --admin-accent: #16658a;
        --admin-accent-strong: #0f5371;
        --admin-success: #1d7a4b;
        --admin-danger: #ad3641;
        --admin-shadow: 0 24px 60px rgba(18, 26, 34, 0.08);
        font-family: Manrope, 'Segoe UI', sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--admin-text);
        background:
          radial-gradient(circle at top left, rgba(22, 101, 138, 0.09), transparent 30%),
          linear-gradient(180deg, #f8f4ee 0%, var(--admin-bg) 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input,
      textarea,
      select {
        font: inherit;
      }

      .admin-shell {
        width: min(100% - 2rem, 1200px);
        margin: 0 auto;
      }

      .admin-topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(14px);
        background: rgba(245, 241, 234, 0.88);
        border-bottom: 1px solid rgba(217, 225, 231, 0.7);
      }

      .admin-topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 4.75rem;
      }

      .admin-brand {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .admin-brand strong {
        font-size: 1rem;
      }

      .admin-brand span {
        color: var(--admin-muted);
        font-size: 0.88rem;
      }

      .admin-nav {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      .admin-nav a {
        padding: 0.8rem 1rem;
        border-radius: 999px;
        color: var(--admin-muted);
        font-weight: 700;
      }

      .admin-nav a.active {
        color: white;
        background: var(--admin-accent);
      }

      .admin-user {
        display: flex;
        align-items: center;
        gap: 0.9rem;
      }

      .admin-user-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: white;
        border: 1px solid var(--admin-border);
        color: var(--admin-muted);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .admin-logout {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.78rem 1rem;
        border: 1px solid var(--admin-border);
        background: white;
        font-weight: 700;
      }

      .admin-main {
        padding: 2rem 0 3rem;
      }

      .admin-card {
        background: var(--admin-panel);
        border: 1px solid var(--admin-border);
        border-radius: 1.5rem;
        box-shadow: var(--admin-shadow);
      }

      .admin-card-soft {
        background: var(--admin-panel-soft);
      }

      .admin-card-body {
        padding: 1.5rem;
      }

      .admin-title {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 0.98;
      }

      .admin-subtitle {
        margin-top: 1rem;
        max-width: 48rem;
        color: var(--admin-muted);
        font-size: 1rem;
        line-height: 1.8;
      }

      .admin-grid {
        display: grid;
        gap: 1rem;
      }

      .admin-grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .admin-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .admin-button,
      .admin-button-secondary,
      .admin-button-danger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.95rem 1.25rem;
        border: 1px solid transparent;
        font-weight: 800;
        cursor: pointer;
      }

      .admin-button {
        background: var(--admin-accent);
        color: white;
      }

      .admin-button:hover {
        background: var(--admin-accent-strong);
      }

      .admin-button-secondary {
        background: white;
        border-color: var(--admin-border);
        color: var(--admin-text);
      }

      .admin-button-danger {
        background: white;
        border-color: rgba(173, 54, 65, 0.2);
        color: var(--admin-danger);
      }

      .admin-form {
        display: grid;
        gap: 1rem;
      }

      .admin-form-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .admin-field {
        display: grid;
        gap: 0.55rem;
      }

      .admin-field label {
        font-weight: 800;
        font-size: 0.92rem;
      }

      .admin-help {
        color: var(--admin-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .admin-field input,
      .admin-field textarea,
      .admin-field select {
        width: 100%;
        padding: 0.95rem 1rem;
        border-radius: 1rem;
        border: 1px solid var(--admin-border);
        background: white;
        color: var(--admin-text);
      }

      .admin-field textarea {
        min-height: 8rem;
        resize: vertical;
      }

      .admin-alert,
      .admin-success {
        padding: 1rem 1.1rem;
        border-radius: 1rem;
        font-weight: 700;
      }

      .admin-alert {
        color: var(--admin-danger);
        background: rgba(173, 54, 65, 0.08);
        border: 1px solid rgba(173, 54, 65, 0.18);
      }

      .admin-success {
        color: var(--admin-success);
        background: rgba(29, 122, 75, 0.08);
        border: 1px solid rgba(29, 122, 75, 0.16);
      }

      .admin-kpi {
        display: grid;
        gap: 0.4rem;
      }

      .admin-kpi strong {
        font-size: 2rem;
        line-height: 1;
      }

      .admin-kpi span {
        color: var(--admin-muted);
      }

      .admin-table {
        width: 100%;
        border-collapse: collapse;
      }

      .admin-table th,
      .admin-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--admin-border);
        text-align: left;
        vertical-align: top;
      }

      .admin-table th {
        color: var(--admin-muted);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .admin-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: rgba(22, 101, 138, 0.08);
        color: var(--admin-accent-strong);
        font-size: 0.84rem;
        font-weight: 800;
      }

      .admin-badge-draft {
        background: rgba(201, 138, 31, 0.12);
        color: #8a5a12;
      }

      .admin-badge-file {
        background: rgba(97, 112, 125, 0.12);
        color: #556471;
      }

      .admin-media-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .admin-media-card {
        overflow: hidden;
        border-radius: 1.2rem;
        background: white;
        border: 1px solid var(--admin-border);
      }

      .admin-media-card img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
      }

      .admin-media-card-body {
        padding: 0.9rem;
        display: grid;
        gap: 0.35rem;
      }

      .admin-sections {
        display: grid;
        gap: 1rem;
      }

      .admin-section-card {
        padding: 1rem;
        border-radius: 1.25rem;
        border: 1px solid var(--admin-border);
        background: var(--admin-panel-soft);
      }

      .admin-editor {
        background: white;
        border: 1px solid var(--admin-border);
        border-radius: 1rem;
        overflow: hidden;
      }

      .admin-editor .ql-toolbar {
        border: 0;
        border-bottom: 1px solid var(--admin-border);
      }

      .admin-editor .ql-container {
        border: 0;
        min-height: 12rem;
      }

      @media (max-width: 900px) {
        .admin-grid-3,
        .admin-form-grid {
          grid-template-columns: 1fr;
        }

        .admin-topbar-inner {
          padding: 0.8rem 0;
          align-items: flex-start;
          flex-direction: column;
        }

        .admin-user {
          width: 100%;
          justify-content: space-between;
        }
      }
    </style>
  </head>
  <body>
    <header class="admin-topbar">
      <div class="admin-shell admin-topbar-inner">
        <div class="admin-brand">
          <strong>Immobilier Auxois Morvan</strong>
          <span>{description}</span>
        </div>

        <nav class="admin-nav" aria-label="Navigation administration">
          {navigation.map((item) => (
            <a href={item.href} class={currentPath === item.href || currentPath.startsWith(`${item.href}/`) ? 'active' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="admin-user">
          {adminName && <span class="admin-user-chip">{adminName}</span>}
          <a href="/admin/logout" class="admin-logout">Déconnexion</a>
        </div>
      </div>
    </header>

    <main class="admin-main">
      <div class="admin-shell">
        <slot />
      </div>
    </main>
  </body>
</html>