---
import { getSiteSettings } from '../lib/content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  image?: string;
}

const siteSettings = await getSiteSettings();

const {
  title,
  description = siteSettings.shortPresentation,
  currentPage = Astro.url.pathname,
  image
} = Astro.props;

const documentTitle = title === siteSettings.siteName ? title : `${title} | ${siteSettings.siteName}`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.href;
const socialImage = image
  ? Astro.site
    ? new URL(image, Astro.site).toString()
    : image
  : undefined;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#18252d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    <title>{documentTitle}</title>
  </head>
  <body class="min-h-screen bg-[color:var(--color-bg)] text-[color:var(--color-ink)] antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[70] focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-[color:var(--color-ink-strong)]">
      Aller au contenu
    </a>
    <Header currentPage={currentPage} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
