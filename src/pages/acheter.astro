---
import MainPageTemplate from '../components/MainPageTemplate.astro';
import { getPageContent } from '../lib/content';

const page = await getPageContent('acheter');

const stats = [
  { value: 'Projet cadré', label: 'Recherche clarifiée' },
  { value: 'Repères terrain', label: 'Villages et bassins de vie' },
  { value: 'Visites utiles', label: 'Accompagnement présent' },
  { value: 'Décision', label: 'Aide à l\'arbitrage' }
];
---

<MainPageTemplate
  page={page}
  currentPage="/acheter"
  eyebrow="Recherche immobilière"
  introEyebrow="Acquisition"
  introTitle="Acheter avec des repères concrets sur le marché local"
  stats={stats}
/>
