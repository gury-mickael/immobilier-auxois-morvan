---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout
  title="Acheter un bien"
  description="Recherche de bien immobilier en Auxois et Morvan. Conseils d'expert pour trouver votre maison ou appartement."
  currentPage="/acheter"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-green-600 to-green-700 text-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Acheter votre bien</h1>
      <p class="text-xl text-green-100 max-w-3xl">
        Trouvez la maison ou l'appartement de vos rêves avec notre expertise locale et notre accompagnement sur chaque étape du projet.
      </p>
    </div>
  </section>

  <!-- Notre accompagnement -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Comment nous vous accompagnons"
        subtitle="Une approche personnalisée et attentive à votre projet"
      />

      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Comprendre vos besoins</h3>
          <ul class="space-y-4">
            <li class="flex gap-4">
              <span class="text-2xl">🎯</span>
              <div>
                <p class="font-semibold text-slate-900">Budget et financement</p>
                <p class="text-slate-600">Nous définissons ensemble votre budget et vous conseillons sur les meilleures solutions de financement.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-2xl">📍</span>
              <div>
                <p class="font-semibold text-slate-900">Localisation idéale</p>
                <p class="text-slate-600">Villages, centre-ville ou campagne : nous trouvons la région qui correspond à votre projet de vie.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-2xl">🏡</span>
              <div>
                <p class="font-semibold text-slate-900">Type de bien</p>
                <p class="text-slate-600">Maison de caractère, appartement modern, terrain : nous saurons ce qui vous plaît vraiment.</p>
              </div>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Trouver et sécuriser l'achat</h3>
          <ul class="space-y-4">
            <li class="flex gap-4">
              <span class="text-2xl">🔍</span>
              <div>
                <p class="font-semibold text-slate-900">Recherche active</p>
                <p class="text-slate-600">Nous recherchons activement les meilleurs biens qui correspondent à vos critères, avant même leur publication.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-2xl">💡</span>
              <div>
                <p class="font-semibold text-slate-900">Conseil d'expert</p>
                <p class="text-slate-600">Évaluations techniques, potentiels de revalorisation, pièges à éviter : nous vous guidons avec expertise.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-2xl">✅</span>
              <div>
                <p class="font-semibold text-slate-900">Concrétiser l'achat</p>
                <p class="text-slate-600">Négociation, documents, visite notaire : nous finalisons votre achat en toute sérénité.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Avantages de notre région -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Pourquoi acheter en Auxois-Morvan ?"
        subtitle="Des régions attractives avec de véritables atouts"
      />

      <div class="grid md:grid-cols-3 gap-8">
        <ServiceCard
          title="Qualité de vie"
          description="Nature préservée, villages pittoresques, dynamique culturelle et paysages remarquables. Un cadre idéal pour les familles et les retraités."
          icon="🌿"
        />
        <ServiceCard
          title="Accessibilité"
          description="Bien connectée à Dijon et Chalon. À proximité de Beaune et de ses vignobles. Routes et transports pratiques."
          icon="🛣️"
        />
        <ServiceCard
          title="Budget accessible"
          description="Les prix de l'immobilier restent raisonnables comparés aux grandes villes. Rendement intéressant pour l'investissement."
          icon="💰"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTASection
        title="Commencez votre recherche"
        description="Parlez-nous de votre projet. Nous vous proposerons une sélection de biens correspondant à vos envies et votre budget."
        primaryButtonText="Nous contacter"
        primaryButtonHref="/contact"
        secondaryButtonText="Demander une estimation"
        secondaryButtonHref="/estimation"
      />
    </div>
  </section>
</Layout>
