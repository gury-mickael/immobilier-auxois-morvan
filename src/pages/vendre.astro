---
import MainPageTemplate from '../components/MainPageTemplate.astro';
import { getPageContent } from '../lib/content';

const page = await getPageContent('vendre');

const stats = [
  { value: 'Prix juste', label: 'Positionnement de départ' },
  { value: 'Diffusion ciblée', label: 'Visibilité commerciale' },
  { value: 'Négociation', label: 'Pilotage des offres' },
  { value: 'Signature', label: 'Suivi jusqu\'au bout' }
];
---

<MainPageTemplate
  page={page}
  currentPage="/vendre"
  eyebrow="Vente immobilière"
  introEyebrow="Stratégie"
  introTitle="Vendre avec une méthode claire et défendue"
  stats={stats}
/>
