---
import { getAdminFromSession, loginAdmin, verifyAdminCredentials } from '../../lib/server/auth';
import { isDatabaseConfigured } from '../../lib/server/config';

const currentAdmin = await getAdminFromSession(Astro.session);

if (currentAdmin) {
  return Astro.redirect('/admin');
}

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = String(formData.get('email') ?? '').trim();
  const password = String(formData.get('password') ?? '');

  if (!isDatabaseConfigured()) {
    errorMessage = 'La base de données n’est pas encore configurée. Renseignez d’abord les variables DB_* côté serveur OVH.';
  } else {
    const user = await verifyAdminCredentials(email, password);

    if (!user) {
      errorMessage = 'Email ou mot de passe incorrect.';
    } else {
      await loginAdmin(Astro.session, user);
      return Astro.redirect('/admin');
    }
  }
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Connexion admin</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Manrope, 'Segoe UI', sans-serif;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        color: #18252d;
        background:
          radial-gradient(circle at top left, rgba(22, 101, 138, 0.12), transparent 32%),
          linear-gradient(180deg, #f8f4ee 0%, #f4efe8 100%);
      }

      .panel {
        width: min(100%, 32rem);
        background: white;
        border: 1px solid #d9e1e7;
        border-radius: 1.75rem;
        padding: 2rem;
        box-shadow: 0 28px 64px rgba(18, 26, 34, 0.1);
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 0.98;
      }

      p {
        color: #66737f;
        line-height: 1.7;
      }

      form {
        display: grid;
        gap: 1rem;
        margin-top: 1.5rem;
      }

      label {
        display: grid;
        gap: 0.45rem;
        font-weight: 800;
      }

      input {
        width: 100%;
        padding: 1rem;
        border-radius: 1rem;
        border: 1px solid #d9e1e7;
        font: inherit;
      }

      button {
        margin-top: 0.5rem;
        border: 0;
        border-radius: 999px;
        padding: 1rem 1.25rem;
        background: #16658a;
        color: white;
        font: inherit;
        font-weight: 800;
        cursor: pointer;
      }

      .error {
        margin-top: 1rem;
        padding: 0.95rem 1rem;
        border-radius: 1rem;
        background: rgba(173, 54, 65, 0.08);
        border: 1px solid rgba(173, 54, 65, 0.18);
        color: #ad3641;
        font-weight: 700;
      }

      .hint {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 1rem;
        background: #f8fbfd;
        border: 1px solid #d9e1e7;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <section class="panel">
      <h1>Connexion admin</h1>
      <p>Accès privé au CMS maison. Authentification par email et mot de passe avec session serveur sécurisée.</p>

      {errorMessage && <div class="error">{errorMessage}</div>}

      <form method="post">
        <label>
          Email
          <input type="email" name="email" autocomplete="email" required />
        </label>

        <label>
          Mot de passe
          <input type="password" name="password" autocomplete="current-password" required />
        </label>

        <button type="submit">Se connecter</button>
      </form>

      <div class="hint">
        Première mise en place : créez les comptes dans la table cms_admin_users avec un mot de passe hashé bcrypt, puis connectez-vous ici.
      </div>
    </section>
  </body>
</html>