---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminFromSession } from '../../lib/server/auth';
import { getAdminBlogPosts, seedCmsFromContentFiles } from '../../lib/server/cms';
import { isDatabaseConfigured } from '../../lib/server/config';

const admin = await getAdminFromSession(Astro.session);

if (!admin) {
  return Astro.redirect('/admin/login');
}

if (Astro.request.method === 'POST') {
  await seedCmsFromContentFiles();
  return Astro.redirect('/admin/blog?seeded=1');
}

const posts = await getAdminBlogPosts();
const databaseReady = isDatabaseConfigured();
const seeded = Astro.url.searchParams.get('seeded') === '1';

function getStatusLabel(status: string) {
  if (status === 'published') return 'Publié';
  if (status === 'draft') return 'Brouillon';
  return 'Fichier source';
}

function getStatusClass(status: string) {
  if (status === 'published') return 'admin-badge';
  if (status === 'draft') return 'admin-badge admin-badge-draft';
  return 'admin-badge admin-badge-file';
}
---

<AdminLayout title="Blog" description="Actualités et conseils" adminName={admin.name} currentPath="/admin/blog">
  <section class="admin-card">
    <div class="admin-card-body">
      <h1 class="admin-title">Blog / actualités</h1>
      <p class="admin-subtitle">Les articles peuvent être importés depuis les fichiers puis édités, mis en brouillon ou publiés depuis la base sans redéploiement.</p>

      {seeded && <div class="admin-success" style="margin-top: 1rem;">Les articles des fichiers ont été importés.</div>}

      <div class="admin-actions" style="margin-top: 1rem;">
        <form method="post">
          <button type="submit" class="admin-button" disabled={!databaseReady}>Importer les articles en base</button>
        </form>
      </div>
    </div>
  </section>

  <section class="admin-card" style="margin-top: 1rem; overflow: hidden;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Titre</th>
          <th>Catégorie</th>
          <th>Slug</th>
          <th>État</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post) => (
          <tr>
            <td>
              <strong>{post.title}</strong>
              <div class="admin-help">{post.excerpt}</div>
            </td>
            <td>{post.category}</td>
            <td>/blog/{post.slug}</td>
            <td><span class={getStatusClass(post.status)}>{getStatusLabel(post.status)}</span></td>
            <td>
              <a href={`/admin/blog/${post.slug}`} class="admin-button-secondary">Modifier</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</AdminLayout>