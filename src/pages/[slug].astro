---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContentSections from '../components/ContentSections.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTASection from '../components/CTASection.astro';
import { getPublishedLocalPages, resolveAssetSrc } from '../lib/content';

export async function getStaticPaths() {
  const pages = await getPublishedLocalPages();

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page, allPages: pages }
  }));
}

const { page, allPages } = Astro.props;
const currentPath = `/${page.data.slug}`;
const heroImage = resolveAssetSrc(page.data.heroImage);

const heroStats = [
  { value: page.data.city, label: 'Ville' },
  { value: page.data.pageType.replaceAll('-', ' '), label: 'Type de page' },
  { value: 'Conseil local', label: 'Approche' },
  { value: 'Publié', label: 'Statut' }
];

const nearbyLinks = page.data.nearbyCities.map((city) => {
  const match = allPages.find((entry) => entry.data.city === city && entry.data.slug !== page.data.slug);

  return {
    city,
    href: match ? `/${match.data.slug}` : '/secteur'
  };
});
---

<Layout title={page.data.title} description={page.data.metaDescription} currentPage={currentPath} image={heroImage}>
  <Hero
    eyebrow="Page locale"
    title={page.data.heroTitle}
    subtitle={page.data.heroSubtitle}
    image={heroImage}
    imageAlt={page.data.heroImageAlt}
    stats={heroStats}
    actions={[
      { label: page.data.ctaButtonLabel, href: page.data.ctaButtonUrl, variant: 'primary' },
      { label: 'Voir notre secteur', href: '/secteur', variant: 'outline' }
    ]}
  />

  <ContentSections intro={page.data.intro} introEyebrow="Ville" introTitle={`Un contenu pensé pour ${page.data.city}`} sections={page.data.sections} />

  <section class="section pt-0">
    <div class="shell grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="surface-panel rounded-[2rem] p-8">
        <SectionHeader eyebrow="Atouts locaux" title={`Pourquoi cette page est utile à ${page.data.city}`} subtitle="Une lecture plus précise du secteur, des attentes acquéreurs et des questions que se posent les propriétaires localement." />
        <ul class="mt-6 grid gap-3">
          {page.data.localAdvantages.map((advantage) => (
            <li class="flex items-start gap-3 text-sm leading-6 text-[color:var(--color-ink)]">
              <span class="mt-2 h-1.5 w-6 rounded-full bg-[color:var(--color-accent)]"></span>
              <span>{advantage}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="surface-panel rounded-[2rem] p-8">
        <SectionHeader eyebrow="Villes proches" title="Poursuivre la navigation locale" subtitle="Retrouvez d'autres points d'entrée locaux quand ils existent, ou revenez à la page secteur pour élargir la recherche." />
        <div class="mt-6 flex flex-wrap gap-3">
          {nearbyLinks.map((item) => (
            <a href={item.href} class="rounded-full border border-[color:var(--color-border-strong)] bg-white/80 px-4 py-2 text-sm font-semibold text-[color:var(--color-ink-strong)] hover:border-[color:var(--color-accent)]">
              {item.city}
            </a>
          ))}
          <a href="/secteur" class="rounded-full border border-[color:var(--color-ink-strong)] bg-[color:var(--color-ink-strong)] px-4 py-2 text-sm font-semibold text-white hover:bg-[#22343d]">
            Voir la page secteur
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title={page.data.ctaTitle}
        description={page.data.ctaText}
        primaryButtonText={page.data.ctaButtonLabel}
        primaryButtonHref={page.data.ctaButtonUrl}
        secondaryButtonText="Découvrir notre secteur"
        secondaryButtonHref="/secteur"
      />
    </div>
  </section>
</Layout>
