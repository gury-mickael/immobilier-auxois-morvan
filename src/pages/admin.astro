---
import AdminLayout from '../layouts/AdminLayout.astro';
import { getAdminFromSession } from '../lib/server/auth';
import { isDatabaseConfigured } from '../lib/server/config';
import { getAdminMainPages } from '../lib/server/cms';
import { listUploadedFiles } from '../lib/server/uploads';

const admin = await getAdminFromSession(Astro.session);

if (!admin) {
  return Astro.redirect('/admin/login');
}

const [pages, media] = await Promise.all([getAdminMainPages(), listUploadedFiles()]);
const databaseReady = isDatabaseConfigured();
const draftCount = pages.filter((page) => page.status === 'draft').length;
---

<AdminLayout title="Tableau de bord" description="Première base du CMS maison" adminName={admin.name} currentPath="/admin">
  <section class="admin-card">
    <div class="admin-card-body">
      <h1 class="admin-title">Tableau de bord</h1>
      <p class="admin-subtitle">
        Le site public reste en ligne comme avant. Les pages principales peuvent maintenant être pilotées depuis la base si elle est configurée, avec repli automatique sur les fichiers actuels tant qu'aucune version publiée n'existe en base.
      </p>
    </div>
  </section>

  <section class="admin-grid admin-grid-3" style="margin-top: 1rem;">
    <article class="admin-card">
      <div class="admin-card-body admin-kpi">
        <strong>{pages.length}</strong>
        <span>pages principales raccordées</span>
      </div>
    </article>
    <article class="admin-card">
      <div class="admin-card-body admin-kpi">
        <strong>{draftCount}</strong>
        <span>brouillons en base</span>
      </div>
    </article>
    <article class="admin-card">
      <div class="admin-card-body admin-kpi">
        <strong>{media.length}</strong>
        <span>médias disponibles</span>
      </div>
    </article>
  </section>

  <section class="admin-card" style="margin-top: 1rem;">
    <div class="admin-card-body">
      <h2 style="margin: 0; font-size: 1.5rem;">État de la migration</h2>
      <div class="admin-grid admin-grid-3" style="margin-top: 1rem;">
        <div class="admin-card admin-card-soft">
          <div class="admin-card-body">
            <strong>Base de données</strong>
            <p class="admin-help">{databaseReady ? 'Configurée. Vous pouvez importer le contenu actuel et commencer les éditions.' : 'Non configurée. Le site public reste sur les fichiers existants tant que les variables DB_* ne sont pas renseignées.'}</p>
          </div>
        </div>
        <div class="admin-card admin-card-soft">
          <div class="admin-card-body">
            <strong>Pages principales</strong>
            <p class="admin-help">Le module d'édition est prêt pour les pages principales avec statut brouillon / publié.</p>
          </div>
        </div>
        <div class="admin-card admin-card-soft">
          <div class="admin-card-body">
            <strong>Médiathèque</strong>
            <p class="admin-help">Upload sécurisé JPG, PNG et WebP dans le dossier uploads de l'hébergement.</p>
          </div>
        </div>
      </div>
      <div class="admin-actions" style="margin-top: 1.25rem;">
        <a href="/admin/pages" class="admin-button">Gérer les pages</a>
        <a href="/admin/local-pages" class="admin-button-secondary">Gérer les pages locales</a>
        <a href="/admin/blog" class="admin-button-secondary">Gérer le blog</a>
        <a href="/admin/media" class="admin-button-secondary">Ouvrir la médiathèque</a>
        <a href="/admin/settings" class="admin-button-secondary">Modifier les paramètres</a>
      </div>
    </div>
  </section>
</AdminLayout>