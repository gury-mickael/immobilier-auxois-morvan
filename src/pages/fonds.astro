---
import MainPageTemplate from '../components/MainPageTemplate.astro';
import { getPageContent } from '../lib/content';

const page = await getPageContent('fonds-de-commerce');

const stats = [
  { value: 'Valorisation', label: 'Activité et environnement' },
  { value: 'Dossier clair', label: 'Supports acquéreurs' },
  { value: 'Diffusion ciblée', label: 'Repreneurs qualifiés' },
  { value: 'Confidentialité', label: 'Accompagnement du cédant' }
];
---

<MainPageTemplate
  page={page}
  currentPage="/fonds"
  eyebrow="Transmission de commerce"
  introEyebrow="Commerce"
  introTitle="Une cession préparée avec méthode, discrétion et qualité de suivi"
  stats={stats}
/>
