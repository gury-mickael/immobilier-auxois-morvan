---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout
  title="Notre secteur d'intervention"
  description="Auxois, Morvan, Autun, Beaune, Dijon, Semur-en-Auxois. Zones de couverture dans l'immobilier en Bourgogne."
  currentPage="/secteur"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-teal-600 to-teal-700 text-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Notre secteur d'intervention</h1>
      <p class="text-xl text-teal-100 max-w-3xl">
        Couvrant l'Auxois, le Morvan et l'ensemble de la Bourgogne du Nord, nous opérons sur plus de 40 communes.
      </p>
    </div>
  </section>

  <!-- Zones principales -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Zones principales"
        subtitle="Les cœurs de notre activité"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { id: 'autun', name: 'Autun', desc: 'Ville d\'histoire, riche patrimoine, marché dynamique. Un centre urbain important pour la région.' },
          { id: 'beaune', name: 'Beaune', desc: 'Capitale mondiale du vin, attractivité touristique forte, marché résidentiel qualité.' },
          { id: 'dijon', name: 'Dijon', desc: 'Grande ville, métropole régionale, dynamique économique et universitaire majeure.' },
          { id: 'semur', name: 'Semur-en-Auxois', desc: 'Village pittoresque, patrimoine médiéval, attractivité résidentielle et touristique.' },
          { id: 'pouilly', name: 'Pouilly-en-Auxois', desc: 'Carrefour stratégique de l\'Auxois, dynamique commerciale, qualité résidentielle.' },
          { id: 'saulieu', name: 'Saulieu', desc: 'Village gourmet, patrimoine culinaire, accès nature, accessibilité régionale.' },
        ].map((zone) => (
          <div id={zone.id} class="bg-gradient-to-br from-teal-50 to-teal-100 rounded-xl p-8 border border-teal-200 hover:shadow-lg transition-shadow">
            <h3 class="text-2xl font-bold text-slate-900 mb-3">{zone.name}</h3>
            <p class="text-slate-700 mb-4">{zone.desc}</p>
            <Button href="/contact" variant="outline" size="sm">
              Demander info
            </Button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Toutes les communes -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Toutes les communes couvertes"
      />

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {['Arnay-le-Duc', 'Autun', 'Beaune', 'Bligny-lès-Beaune', 'Bouze-lès-Beaune', 'Brazey-en-Morvan', 'Chaligny', 'Chalon-sur-Saône', 'Champ-d\'Oiseau', 'Change', 'Chemin', 'Chevilly', 'Clamecy', 'Communes', 'Courcelle-Frémoy', 'Coutances', 'Darcey', 'Dijon', 'Dracy', 'Église', 'Épinac', 'Essarois', 'Étais-la-Sauvin', 'Fontaines-lès-Blancs', 'Froideville', 'Gilly-lès-Cîteaux', 'Glanon', 'Goux', 'Grésigne', 'Grosbois', 'Igornay', 'Jallanges', 'Jugon', 'Lacanche', 'Lassey', 'Liernais', 'Lucenay-l\'Évêque', 'Lucey', 'Luzy', 'Magnien', 'Marigny-l\'Église', 'Maroilles', 'Mauroux', 'Melay', 'Meloisey', 'Menaudes', 'Merceuil', 'Méthorey', 'Meursault', 'Meuzard', 'Moisy', 'Molay', 'Montceau-les-Mines', 'Montiche', 'Mont-Saint-Vincent', 'Montsauche-les-Setreaux', 'Morey-Saint-Denis', 'Mornay', 'Mornay-Berry', 'Morvan', 'Mouley', 'Moulin-Engilbert', 'Mourouge', 'Mouries', 'Nantoux', 'Narvoux', 'Neuffontaines', 'Neuilly', 'Neuilly-lès-Bois', 'Nevers', 'Nielles', 'Nod-sur-Seineportions', 'Nolay', 'Nucs', 'Olonne-sur-Cosnon', 'Ouzels', 'Ouzouer-le-Marché', 'Panges', 'Pardines', 'Parigny-les-Vaux', 'Passavant', 'Paveaux', 'Pavillon', 'Paxieux', 'Paynal', 'Paysages', 'Pays-Blanc', 'Paysy-les-Bois', 'Pouilly-en-Auxois', 'Pouilly-sous-Charlieu', 'Pouilly-sur-Loire', 'Pouilly-sur-Vingeanne', 'Saulieu', 'Savoie', 'Scey-machen', 'Semur-en-Auxois', 'Semur-en-Brionnais', 'Senailly', 'Sennecy-le-Grand', 'Sennecey-lès-Dijon', 'Sennelier', 'Senozan', 'Senouard', 'Seppois-le-Bas', 'Sère', 'Serez', 'Serfaty', 'Sérignan', 'Seringes-et-Nesles', 'Sermizelles', 'Serrigny', 'Serrigny-en-Bresse', 'Serzy', 'Seuillet', 'Seuray', 'Seurey', 'Sevelinges', 'Seveux', 'Sèvres-Anxaumont'].map((commune) => (
          <div class="bg-white rounded-lg p-4 shadow-sm border border-slate-100 hover:border-teal-300 hover:shadow-md transition-all text-center">
            <p class="font-medium text-slate-900 text-sm">{commune}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Secteur Auxois -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-slate-900 mb-8">L'Auxois en détail</h2>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Caractéristiques</h3>
            <p class="text-slate-600">
              L'Auxois est une région historique et magnifique du nord de la Bourgogne. Ses paysages varient entre plateaux agricoles, forêts, et vallées pittoresques. C'est un véritable joyau pour ceux en quête de calme et de qualité de vie.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Marché immobilier</h3>
            <p class="text-slate-600">
              Un marché équilibré avec une bonne demande de propriétés résidentielles. Les prix restent raisonnables comparés aux grandes villes, offrant une excellente opportunité pour les investisseurs et les familles.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Attractivité</h3>
            <p class="text-slate-600">
              Proximité de Dijon, Beaune et Chalon. Villages de caractère, patrimoine remarquable, gastronomie locale, accès direct à la nature et aux activités.
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Secteur Morvan</h3>
            <p class="text-slate-600">
              Le Morvan offre un cadre naturel exceptionnel : lacs, forêts, randonnées. Un secteur très attractif pour les retraités, les familles et les amateurs de nature.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Tendances</h3>
            <p class="text-slate-600">
              Hausse de la demande pour les propriétés rurales et travaux récente. Développement du télétravail augmente l'intérêt pour cette région. Des prix stables et attractifs.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Nos recommandations</h3>
            <p class="text-slate-600">
              Agir rapidement sur les bonnes opportunités. Investir dans des travaux de rénovation pour maximiser la valeur. Considérer les villages avec accès facile à Dijon.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTASection
        title="Vous cherchez dans une zone spécifique ?"
        description="Nous connaissons chaque quartier, chaque village. Contactez-nous pour une recherche personnalisée dans votre secteur préféré."
        primaryButtonText="Nous contacter"
        primaryButtonHref="/contact"
        secondaryButtonText="Demander une estimation"
        secondaryButtonHref="/estimation"
      />
    </div>
  </section>
</Layout>
