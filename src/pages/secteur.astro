---
import MainPageTemplate from '../components/MainPageTemplate.astro';
import SectionHeader from '../components/SectionHeader.astro';
import AreaCard from '../components/AreaCard.astro';
import LocalPageCard from '../components/LocalPageCard.astro';
import { getPageContent, getPublishedLocalPages, getSiteSettings, resolveAssetSrc } from '../lib/content';

const [page, localPages, siteSettings] = await Promise.all([
  getPageContent('secteur'),
  getPublishedLocalPages(),
  getSiteSettings()
]);

const stats = [
  { value: 'Arnay-le-Duc', label: 'Ville repère' },
  { value: 'Pouilly-en-Auxois', label: 'Axe central' },
  { value: 'Autun à Dijon', label: 'Bassins de vie suivis' },
  { value: 'Auxois & Morvan', label: 'Territoires complémentaires' }
];

const areaDescriptions: Record<string, string> = {
  'Arnay-le-Duc': 'Un secteur où la proximité, le cadre de vie et les villages voisins influencent fortement la demande.',
  'Pouilly-en-Auxois': 'Un point de liaison important entre déplacements, projets résidentiels et attractivité locale.',
  Autun: 'Un marché qui demande une vraie lecture des quartiers, des typologies de biens et des attentes acquéreurs.',
  Saulieu: 'Une ville de passage et de vie locale, avec des enjeux spécifiques selon l\'emplacement et le profil du bien.',
  Beaune: 'Un secteur recherché où l\'emplacement et la qualité perçue structurent fortement le positionnement.',
  Dijon: 'Une zone plus large à lire avec précision pour arbitrer entre accessibilité, cadre de vie et stratégie immobilière.',
  Vitteaux: 'Un bassin de proximité intéressant pour les projets résidentiels recherchant un équilibre local.',
  'Semur-en-Auxois': 'Un secteur patrimonial et résidentiel où la finesse d\'analyse du bien reste déterminante.',
  Auxois: 'Un territoire de villages et de petites villes où les micro-marchés doivent être regardés avec nuance.',
  Morvan: 'Un secteur de cadre de vie et de projets de nature, avec des attentes acquéreurs souvent très ciblées.'
};

const areaImages: Record<string, string> = {
  'Arnay-le-Duc': '/uploads/arnay.jpg',
  'Pouilly-en-Auxois': '/uploads/pouilly.jpg',
  Autun: '/uploads/autun.jpg',
  Saulieu: '/uploads/saulieu.jpg',
  Beaune: '/uploads/beaune.jpg',
  Dijon: '/uploads/dijon.jpg',
  Vitteaux: '/uploads/vitteaux.jpg'
};
---

<MainPageTemplate
  page={page}
  currentPage="/secteur"
  eyebrow="Implantation locale"
  introEyebrow="Territoire"
  introTitle="Un conseil local qui s'appuie sur la réalité des secteurs"
  stats={stats}
>
  <section class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Zones couvertes" title="Villes et territoires suivis" subtitle="Des secteurs complémentaires, du village à la ville, avec des logiques de marché et de projet différentes." />
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {siteSettings.coveredAreas.map((area) => (
          <AreaCard title={area} description={areaDescriptions[area] ?? 'Un secteur suivi localement pour sa demande, son cadre de vie et ses spécificités immobilières.'} image={areaImages[area]} />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0" id="pages-locales">
    <div class="shell">
      <SectionHeader eyebrow="Pages locales" title="Pages locales déjà publiées" subtitle="Le site est prêt à accueillir de nouvelles pages SEO par ville, intention ou typologie de projet." />
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {localPages.map((localPage) => (
          <LocalPageCard
            title={localPage.data.h1}
            city={localPage.data.city}
            pageType={localPage.data.pageType}
            href={`/${localPage.data.slug}`}
            excerpt={localPage.data.intro}
            image={resolveAssetSrc(localPage.data.heroImage)}
          />
        ))}
      </div>
    </div>
  </section>
</MainPageTemplate>
