---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import LocalPageCard from '../components/LocalPageCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import {
  formatLongDate,
  getPageContent,
  getPublishedBlogPosts,
  getPublishedLocalPages,
  getPublishedTestimonials,
  getSiteSettings,
  resolveAssetSrc
} from '../lib/content';

const [page, blogPosts, localPages, testimonials, siteSettings] = await Promise.all([
  getPageContent('accueil'),
  getPublishedBlogPosts(),
  getPublishedLocalPages(),
  getPublishedTestimonials(),
  getSiteSettings()
]);

const heroImage = resolveAssetSrc(page.data.heroImage);
const reassurance = page.data.sections[0];
const whyUs = page.data.sections[1];
const iadSupport = page.data.sections[2];
const featuredPosts = blogPosts.slice(0, 3);

const heroActions = [
  { label: 'Faire estimer mon bien', href: '/estimation', variant: 'primary' as const },
  { label: 'Nous contacter', href: '/contact', variant: 'outline' as const }
];

const heroStats = [
  { value: siteSettings.mainCity, label: 'Ville repère' },
  { value: 'Auxois & Morvan', label: 'Secteur couvert' },
  { value: 'IAD France', label: 'Réseau national' },
  { value: 'Suivi humain', label: 'Méthode de travail' }
];

const services = [
  {
    title: 'Vendre',
    description: 'Positionner votre bien au bon prix, le valoriser et piloter la vente jusqu\'à la signature.',
    href: '/vendre',
    features: ['Estimation juste', 'Diffusion ciblée', 'Négociation pilotée']
  },
  {
    title: 'Acheter',
    description: 'Comparer les secteurs, affiner la recherche et avancer avec des repères concrets sur le terrain.',
    href: '/acheter',
    features: ['Lecture du marché local', 'Accompagnement des visites', 'Aide à la décision']
  },
  {
    title: 'Estimation',
    description: 'Obtenir un avis de valeur argumenté pour préparer une mise en vente ou arbitrer un projet.',
    href: '/estimation',
    features: ['Analyse locale', 'Spécificités du bien', 'Conseil utile à la décision']
  },
  {
    title: 'Fonds de commerce',
    description: 'Structurer une transmission, présenter le dossier et qualifier les repreneurs avec discrétion.',
    href: '/fonds',
    features: ['Valorisation', 'Dossier acquéreur', 'Accompagnement jusqu\'à la vente']
  }
];

const areaDescriptions: Record<string, string> = {
  'Arnay-le-Duc': 'Un marché de proximité où la lecture du cadre de vie et des villages environnants fait la différence.',
  'Pouilly-en-Auxois': 'Un secteur charnière entre mobilité, vie locale et recherche résidentielle dans l\'Auxois.',
  Autun: 'Un bassin de vie structuré, avec des quartiers et profils acquéreurs à bien distinguer.',
  Saulieu: 'Une ville d\'équilibre entre centralité locale, patrimoine et environnement naturel recherché.',
  Beaune: 'Un marché attractif où l\'emplacement, la qualité du bien et le projet acquéreur pèsent fortement.',
  Dijon: 'Une zone plus large où l\'accompagnement local aide à mieux arbitrer les opportunités et les secteurs.'
};

const areaImages: Record<string, string> = {
  'Arnay-le-Duc': '/uploads/arnay.jpg',
  'Pouilly-en-Auxois': '/uploads/pouilly.jpg',
  Autun: '/uploads/autun.jpg',
  Saulieu: '/uploads/saulieu.jpg',
  Beaune: '/uploads/beaune.jpg',
  Dijon: '/uploads/dijon.jpg'
};
---

<Layout title={page.data.title} description={page.data.metaDescription} currentPage="/" image={heroImage}>
  <Hero eyebrow="Conseillers immobiliers locaux" title={page.data.heroTitle} subtitle={page.data.heroSubtitle} actions={heroActions} stats={heroStats} image={heroImage} imageAlt={page.data.heroImageAlt} />

  <section id="histoire" class="section pt-0">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="surface-panel rounded-[1.5rem] p-8 md:p-10">
          <div>
            <p class="eyebrow">Immobilier en Auxois et Morvan</p>
            <h2 class="mt-5 text-4xl leading-tight md:text-5xl">{reassurance.title}</h2>
            <p class="mt-5 max-w-3xl text-[1.02rem] leading-8 text-[color:var(--color-muted)]">{reassurance.text}</p>
            <ul class="mt-6 grid gap-3">
              {reassurance.items?.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-7 text-[color:var(--color-ink)]">
                  <span class="mt-3 h-1.5 w-8 rounded-full bg-[color:var(--color-accent)]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>

        <div class="surface-muted rounded-[1.5rem] p-8 md:p-10">
          <p class="eyebrow">Qui sommes-nous ?</p>
          <h2 class="mt-5 text-4xl leading-tight md:text-5xl">{siteSettings.mickaelName} & {siteSettings.marionName}</h2>
          <p class="mt-5 text-[1.02rem] leading-8 text-[color:var(--color-muted)]">
            {siteSettings.baseline}
          </p>
          <div class="mt-8 grid gap-px rounded-[1rem] border border-[color:var(--color-border)] bg-[color:var(--color-border)] sm:grid-cols-2">
            {siteSettings.coveredAreas.slice(0, 4).map((item) => (
              <div class="bg-white px-5 py-4 text-sm font-semibold text-[color:var(--color-ink-strong)]">
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="prestations" class="section pt-0">
    <div class="shell grid gap-6 lg:grid-cols-2">
      <FeatureCard title={whyUs.title} text={whyUs.text} items={whyUs.items} />
      <FeatureCard title="Une méthode posée, lisible et défendue sur le terrain" text={page.data.intro} items={reassurance.items} />
    </div>
  </section>

  <section id="avis-clients" class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Services" title="Nos services" subtitle="Une présence utile pour vendre, acheter, estimer un bien ou préparer une transmission de commerce." />
      <div class="mt-10 grid gap-6 lg:grid-cols-4">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell grid gap-10">
      <div>
        <SectionHeader eyebrow="Secteur local" title="Notre secteur local" subtitle="Des repères concrets sur les villes et bassins de vie où nous accompagnons régulièrement des projets immobiliers." />
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {siteSettings.coveredAreas.slice(0, 6).map((area) => (
            <AreaCard title={area} description={areaDescriptions[area] ?? 'Un secteur suivi avec attention pour ses dynamiques de marché, ses profils acquéreurs et ses projets de vie.'} image={areaImages[area]} />
          ))}
        </div>
      </div>

      <div>
        <SectionHeader eyebrow="SEO local" title="Quelques pages locales déjà prêtes" subtitle="Le site peut accueillir facilement de nouvelles pages ciblées par ville ou intention de recherche." />
        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {localPages.map((localPage) => (
            <LocalPageCard
              title={localPage.data.h1}
              city={localPage.data.city}
              pageType={localPage.data.pageType}
              href={`/${localPage.data.slug}`}
              excerpt={localPage.data.intro}
              image={resolveAssetSrc(localPage.data.featuredImage)}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <div class="surface-panel rounded-[1.5rem] p-8 md:p-10">
        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
          <SectionHeader eyebrow={iadSupport.eyebrow} title={iadSupport.title} subtitle={iadSupport.text} />
          <div class="grid gap-4 sm:grid-cols-2">
            {(iadSupport.stats ?? []).map((stat) => (
              <div class="rounded-[1rem] border border-[color:var(--color-border)] bg-white px-5 py-5">
                <p class="text-2xl font-semibold text-[color:var(--color-ink-strong)]">{stat.value}</p>
                <p class="mt-1 text-sm text-[color:var(--color-muted)]">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Avis clients" title="Des retours fondés sur la qualité du suivi" subtitle="Des échanges clairs, une présence régulière et une vraie lecture du terrain pour accompagner le projet jusqu\'au bout." />
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <TestimonialCard
            quote={testimonial.quote}
            author={testimonial.data.name}
            title={testimonial.data.propertyType}
            location={testimonial.data.location}
            rating={testimonial.data.rating}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Blog" title="Derniers articles" subtitle="Des contenus utiles pour comprendre le marché local, préparer une vente et cadrer un projet immobilier." />
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {featuredPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            excerpt={post.data.excerpt}
            href={`/blog/${post.data.slug}`}
            category={post.data.category}
            date={formatLongDate(post.data.date)}
            image={resolveAssetSrc(post.data.featuredImage)}
            imageAlt={post.data.featuredImageAlt}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title={page.data.ctaTitle}
        description={page.data.ctaText}
        primaryButtonText={page.data.ctaButtonLabel}
        primaryButtonHref={page.data.ctaButtonUrl}
        secondaryButtonText="Nous contacter"
        secondaryButtonHref="/contact"
      />
    </div>
  </section>
</Layout>
