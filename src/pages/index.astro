---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import LocalPageCard from '../components/LocalPageCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import {
  formatLongDate,
  getPageContent,
  getPublishedBlogPosts,
  getPublishedLocalPages,
  getPublishedTestimonials,
  getSiteSettings,
  resolveAssetSrc
} from '../lib/content';

const [page, blogPosts, localPages, testimonials, siteSettings] = await Promise.all([
  getPageContent('accueil'),
  getPublishedBlogPosts(),
  getPublishedLocalPages(),
  getPublishedTestimonials(),
  getSiteSettings()
]);

const heroImage = resolveAssetSrc(page.data.heroImage);
const featuredPosts = blogPosts.slice(0, 3);
const featuredTestimonials = testimonials.slice(0, 2);

const services = [
  { title: 'Vendre', description: 'Positionner votre bien au bon prix, le valoriser et piloter la vente jusqu\'à la signature.', href: '/vendre', features: ['Estimation juste', 'Diffusion ciblée', 'Négociation pilotée'] },
  { title: 'Acheter', description: 'Comparer les secteurs, affiner la recherche et avancer avec des repères concrets sur le terrain.', href: '/acheter', features: ['Lecture du marché local', 'Accompagnement des visites', 'Aide à la décision'] },
  { title: 'Estimation', description: 'Obtenir un avis de valeur argumenté pour préparer une mise en vente ou arbitrer un projet.', href: '/estimation', features: ['Analyse locale', 'Spécificités du bien', 'Conseil utile à la décision'] },
  { title: 'Fonds de commerce', description: 'Structurer une transmission, présenter le dossier et qualifier les repreneurs avec discrétion.', href: '/fonds', features: ['Valorisation', 'Dossier acquéreur', 'Accompagnement jusqu\'à la vente'] }
];

const areaDescriptions: Record<string, string> = {
  'Arnay-le-Duc': 'Un marché de proximité où la lecture du cadre de vie fait la différence.',
  'Pouilly-en-Auxois': 'Un secteur charnière entre mobilité, vie locale et recherche résidentielle.',
  Autun: 'Un bassin de vie structuré, avec des quartiers et profils acquéreurs distincts.',
  Saulieu: 'Une ville d\'équilibre entre centralité, patrimoine et environnement naturel.',
  Beaune: 'Un marché attractif où l\'emplacement et la qualité du bien pèsent fortement.',
  Dijon: 'Une zone plus large où l\'accompagnement local aide à mieux arbitrer.'
};

const areaImages: Record<string, string> = {
  'Arnay-le-Duc': '/uploads/arnay.jpg',
  'Pouilly-en-Auxois': '/uploads/pouilly.jpg',
  Autun: '/uploads/autun.jpg',
  Saulieu: '/uploads/saulieu.jpg',
  Beaune: '/uploads/beaune.jpg',
  Dijon: '/uploads/dijon.jpg'
};

const areaPriority = ['Arnay-le-Duc', 'Pouilly-en-Auxois', 'Autun', 'Saulieu', 'Beaune', 'Dijon'];
const featuredAreas = areaPriority.filter((area) => siteSettings.coveredAreas.includes(area)).slice(0, 6);

const highlightedLocalSlugs = [
  'estimation-immobiliere-arnay-le-duc',
  'estimation-immobiliere-pouilly-en-auxois',
  'vendre-maison-autun'
];
const featuredLocalPages = highlightedLocalSlugs
  .flatMap((slug) => {
    const match = localPages.find((entry) => entry.data.slug === slug);
    return match ? [match] : [];
  });

const marqueeCities = [...siteSettings.coveredAreas, ...siteSettings.coveredAreas];

const heroPeople = [
  {
    name: siteSettings.mickaelName,
    image: siteSettings.mickaelPhoto ? resolveAssetSrc(siteSettings.mickaelPhoto) : undefined
  },
  {
    name: siteSettings.marionName,
    image: siteSettings.marionPhoto ? resolveAssetSrc(siteSettings.marionPhoto) : undefined
  }
];

const teaserItems = [
  { label: 'Estimation argumentée', text: 'Un avis de valeur lisible, ancré dans le marché local.' },
  { label: 'Stratégie de vente', text: 'Un plan d\'action clair, ciblé, tenu sur la durée.' },
  { label: 'Mise en valeur', text: 'Visuels, discours, présentation — chaque détail compte.' },
  { label: 'Suivi humain', text: 'Une présence régulière jusqu\'à l\'acte authentique.' }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: siteSettings.siteName,
  description: page.data.metaDescription,
  url: Astro.site ? new URL('/', Astro.site).toString() : Astro.url.origin,
  image: heroImage && Astro.site ? new URL(heroImage, Astro.site).toString() : heroImage,
  telephone: siteSettings.phone,
  email: siteSettings.email,
  areaServed: siteSettings.coveredAreas.map((area) => ({ '@type': 'City', name: area })),
  sameAs: [siteSettings.facebookUrl, siteSettings.instagramUrl, siteSettings.iadUrl].filter(Boolean)
};
---

<Layout title={page.data.title} description={page.data.metaDescription} currentPage="/" image={heroImage} structuredData={structuredData}>

  <section class="relative overflow-hidden pt-6 pb-20 md:pt-12 md:pb-28">
    <div class="shell">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:items-center">
        <div class="reveal">
          <p class="eyebrow">Conseillers immobiliers locaux</p>
          <h1 class="mt-6 display-1 balanced-text">
            Vendre, acheter ou estimer un bien <span class="display-italic text-[color:var(--color-accent-strong)]">en Auxois-Morvan.</span>
          </h1>
          <p class="mt-7 max-w-xl text-[1.02rem] leading-[1.8] text-[color:var(--color-muted)] md:text-[1.08rem]">
            {siteSettings.mickaelName} & {siteSettings.marionName} vous accompagnent localement avec le réseau IAD — de l'estimation à la signature.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <Button href="/estimation" size="lg" variant="primary">Faire estimer mon bien</Button>
            <Button href="/contact" size="lg" variant="outline">Nous contacter</Button>
          </div>

          <div class="mt-12 flex items-center gap-5">
            <div class="flex -space-x-3">
              {heroPeople.map((p) => (
                p.image ? (
                  <img src={p.image} alt={p.name} class="h-12 w-12 rounded-full object-cover ring-4 ring-[color:var(--color-bg)]" loading="eager" decoding="async" />
                ) : (
                  <div class="h-12 w-12 rounded-full bg-[color:var(--color-accent-soft)] ring-4 ring-[color:var(--color-bg)] flex items-center justify-center font-[family-name:var(--font-display)] font-semibold text-[color:var(--color-accent-strong)]">
                    {p.name.charAt(0)}
                  </div>
                )
              ))}
            </div>
            <div class="text-sm leading-tight">
              <p class="font-medium text-[color:var(--color-ink-strong)]">{heroPeople.map((p) => p.name).join(' & ')}</p>
              <p class="text-[color:var(--color-muted)]">Vos conseillers locaux · Réseau IAD</p>
            </div>
          </div>
        </div>

        <div class="reveal relative">
          <div class="zoom-img relative aspect-[4/5] w-full overflow-hidden rounded-[2rem] bg-[color:var(--color-bg-warm)]">
            {heroImage ? (
              <img src={heroImage} alt={page.data.heroImageAlt ?? 'Auxois Morvan'} class="h-full w-full object-cover" loading="eager" decoding="async" />
            ) : (
              <div class="flex h-full items-center justify-center font-[family-name:var(--font-display)] text-2xl text-[color:var(--color-muted)]">Auxois · Morvan</div>
            )}
          </div>
          <div class="absolute -bottom-5 left-3 max-w-[16rem] rounded-2xl bg-white p-5 md:-bottom-8 md:left-auto md:-right-6 md:p-6">
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Secteur couvert</p>
            <p class="mt-2 font-[family-name:var(--font-display)] text-[1.6rem] leading-tight text-[color:var(--color-ink-strong)] md:text-[1.85rem]">Auxois & Morvan</p>
            <p class="mt-1 text-xs text-[color:var(--color-muted)]">Côte-d'Or · Bourgogne</p>
          </div>
          <div class="absolute -top-3 -left-3 hidden rounded-2xl bg-[color:var(--color-dark)] p-5 text-white md:block md:-top-6 md:-left-6 md:p-6">
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-white/60">Présence</p>
            <p class="mt-2 stat-number text-white">100%</p>
            <p class="mt-1 text-xs text-white/60">Locale & humaine</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-soft overflow-hidden py-8">
    <div class="marquee-track whitespace-nowrap font-[family-name:var(--font-display)] text-[2.2rem] leading-none text-[color:var(--color-ink-strong)] md:text-[3.5rem]">
      {marqueeCities.map((city) => (
        <span class="inline-flex items-center gap-12 pr-12">
          <span>{city}</span>
          <span class="text-[color:var(--color-warm)]">✦</span>
        </span>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:gap-14">
        <div class="surface-warm rounded-[2rem] p-8 md:p-12">
          <p class="eyebrow">Notre approche</p>
          <h2 class="mt-6 display-2">Deux conseillers locaux, un même cap.</h2>
          <p class="mt-6 text-[1rem] leading-[1.8] text-[color:var(--color-ink)]">
            Basés en Auxois, nous accompagnons vendeurs, acheteurs et porteurs de projets dans le Morvan, la Côte-d'Or et la Bourgogne. Un suivi clair, humain et régulier — avec l'appui du réseau IAD.
          </p>
          <div class="mt-8">
            <Button href="/histoire" variant="primary" size="lg">Découvrir notre histoire</Button>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {teaserItems.map((item, i) => (
            <article class:list={['rounded-[1.5rem] p-6 lift', i % 2 === 0 ? 'surface-soft' : 'surface-accent']}>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-[color:var(--color-accent)]">0{i + 1}</p>
              <h3 class="mt-4 font-[family-name:var(--font-display)] text-[1.3rem] leading-tight">{item.label}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--color-muted)]">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeader eyebrow="Prestations" title="Un accompagnement clair pour chaque projet." />
        <a href="/prestations" class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]">
          Toutes nos prestations
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {services.map((service, i) => (
          <ServiceCard {...service} index={i + 1} />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Secteur local" title="Nos villes et bassins de vie suivis." subtitle="Des repères concrets pour vendre, acheter ou estimer un bien dans l'Auxois-Morvan." />
      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {featuredAreas.map((area) => (
          <AreaCard
            title={area}
            description={areaDescriptions[area] ?? 'Un secteur suivi avec attention pour ses dynamiques de marché et ses profils acquéreurs.'}
            image={areaImages[area]}
            href="/secteur"
          />
        ))}
      </div>
      <div class="mt-10">
        <Button href="/secteur" variant="outline" size="lg">Voir tout notre secteur</Button>
      </div>
    </div>
  </section>

  {featuredTestimonials.length > 0 && (
    <section class="section pt-0">
      <div class="shell">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <SectionHeader eyebrow="Avis clients" title="Ce que disent celles et ceux que nous avons accompagnés." />
          <a href="/avis" class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]">
            Tous les avis
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {featuredTestimonials.map((t, i) => (
            <TestimonialCard
              quote={t.quote}
              author={t.data.name}
              title={t.data.propertyType}
              location={t.data.location}
              rating={t.data.rating}
              variant={i === 0 ? 'warm' : 'soft'}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {featuredLocalPages.length > 0 && (
    <section class="section pt-0">
      <div class="shell">
        <SectionHeader eyebrow="Conseils locaux" title="Nos pages locales par ville." subtitle="Repères concrets, ville par ville, pour préparer une vente ou cadrer un projet." />
        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {featuredLocalPages.map((localPage) => (
            <LocalPageCard
              title={localPage.data.h1}
              city={localPage.data.city}
              pageType={localPage.data.pageType}
              href={`/${localPage.data.slug}`}
              excerpt={localPage.data.intro}
              image={resolveAssetSrc(localPage.data.heroImage)}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {featuredPosts.length > 0 && (
    <section class="section pt-0">
      <div class="shell">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <SectionHeader eyebrow="Blog" title="Conseils & lectures du marché." />
          <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]">
            Tous les articles
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {featuredPosts.map((post) => (
            <BlogCard
              title={post.data.displayTitle ?? post.data.title}
              excerpt={post.data.excerpt}
              href={`/blog/${post.data.slug}`}
              category={post.data.category}
              date={formatLongDate(post.data.date)}
              image={resolveAssetSrc(post.data.featuredImage)}
              imageAlt={post.data.featuredImageAlt}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title={page.data.ctaTitle}
        description={`<p>${page.data.ctaText}</p>`}
        primaryButtonText={page.data.ctaButtonLabel}
        primaryButtonHref={page.data.ctaButtonUrl}
        secondaryButtonText="Nous contacter"
        secondaryButtonHref="/contact"
      />
    </div>
  </section>
</Layout>
