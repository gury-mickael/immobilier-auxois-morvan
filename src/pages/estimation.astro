---
import MainPageTemplate from '../components/MainPageTemplate.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LocalPageCard from '../components/LocalPageCard.astro';
import { getPageContent, getPublishedLocalPages, getSiteSettings, resolveAssetSrc } from '../lib/content';

const [page, localPages, siteSettings] = await Promise.all([
  getPageContent('estimation'),
  getPublishedLocalPages(),
  getSiteSettings()
]);

const stats = [
  { value: 'Avis de valeur', label: 'Argumenté et local' },
  { value: 'Références', label: 'Marché et concurrence' },
  { value: 'Spécificités', label: 'Analyse du bien' },
  { value: 'Décision', label: 'Suite du projet' }
];
---

<MainPageTemplate
  page={page}
  currentPage="/estimation"
  eyebrow="Avis de valeur"
  introEyebrow="Méthode"
  introTitle="Une estimation utile à la décision"
  stats={stats}
>
  <section class="section pt-0">
    <div class="shell grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
      <div class="grid gap-6">
        <div class="surface-panel rounded-[2rem] p-8">
          <SectionHeader eyebrow="Contact direct" title="Préparer votre demande d'estimation" subtitle="Quelques éléments simples suffisent pour engager un premier échange clair et utile sur votre bien." />
          <div class="mt-6 grid gap-4 text-sm text-[color:var(--color-ink)]">
            <a href={`tel:${siteSettings.phone.replace(/\s+/g, '')}`} class="surface-muted rounded-[1.35rem] px-5 py-4 font-semibold">
              {siteSettings.phone}
            </a>
            <a href={`mailto:${siteSettings.email}`} class="surface-muted rounded-[1.35rem] px-5 py-4 font-semibold break-all">
              {siteSettings.email}
            </a>
          </div>
        </div>

        <div class="surface-panel rounded-[2rem] p-8">
          <SectionHeader eyebrow="Pages locales" title="Exemples d'estimations locales" subtitle="Des pages dédiées sont déjà prêtes pour répondre aux recherches locales les plus fréquentes." />
          <div class="mt-6 grid gap-4">
            {localPages.map((localPage) => (
              <LocalPageCard
                title={localPage.data.h1}
                city={localPage.data.city}
                pageType={localPage.data.pageType}
                href={`/${localPage.data.slug}`}
                excerpt={localPage.data.intro}
                image={resolveAssetSrc(localPage.data.heroImage)}
              />
            ))}
          </div>
        </div>
      </div>

      <form class="surface-panel rounded-[2rem] p-8 md:p-10" action="#" method="post">
        <SectionHeader eyebrow="Formulaire" title="Demander une estimation" subtitle="Ce formulaire reste volontairement côté front dans cette version, en attendant une future gestion via CMS GitHub." />

        <div class="mt-8 grid gap-5 md:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
            Nom
            <input class="rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="name" placeholder="Votre nom" required />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
            Email
            <input class="rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="email" name="email" placeholder="vous@exemple.fr" required />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
            Téléphone
            <input class="rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="tel" name="phone" placeholder="06 00 00 00 00" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
            Type de bien
            <select class="rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="propertyType" required>
              <option value="">Choisir un type</option>
              <option value="maison">Maison</option>
              <option value="appartement">Appartement</option>
              <option value="terrain">Terrain</option>
              <option value="fonds">Fonds de commerce</option>
              <option value="autre">Autre</option>
            </select>
          </label>
        </div>

        <label class="mt-5 grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
          Commune du bien
          <input class="rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="city" placeholder="Arnay-le-Duc, Autun, Beaune..." required />
        </label>

        <label class="mt-5 grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
          Description du bien
          <textarea class="min-h-44 rounded-[1.5rem] border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="message" placeholder="Surface, état, nombre de pièces, dépendances, travaux, calendrier de vente..." required></textarea>
        </label>

        <label class="mt-5 flex items-start gap-3 text-sm leading-6 text-[color:var(--color-muted)]">
          <input type="checkbox" name="privacy" required class="mt-1 h-4 w-4 rounded border-[color:var(--color-border)] text-[color:var(--color-accent)]" />
          <span>J'accepte d'être recontacté au sujet de ma demande. Aucun backend ni stockage serveur n'est ajouté dans cette version du site.</span>
        </label>

        <button type="submit" class="mt-6 inline-flex rounded-full border border-[color:var(--color-ink-strong)] bg-[color:var(--color-ink-strong)] px-6 py-3 text-sm font-semibold text-white shadow-[0_12px_28px_rgba(24,37,45,0.18)] hover:-translate-y-0.5 hover:bg-[#22343d]">
          Envoyer ma demande
        </button>
      </form>
    </div>
  </section>
</MainPageTemplate>
