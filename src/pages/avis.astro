---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
import { getPublishedTestimonials, getSiteSettings } from '../lib/content';

const [testimonials, siteSettings] = await Promise.all([
  getPublishedTestimonials(),
  getSiteSettings()
]);

const variants: Array<'soft' | 'warm' | 'panel' | 'accent'> = ['soft', 'warm', 'panel'];
const cardVariant = (i: number) => (['soft', 'warm', 'panel'][i % 3] as 'soft' | 'warm' | 'panel');

const averageRating = testimonials.length
  ? (testimonials.reduce((acc, t) => acc + (t.data.rating ?? 5), 0) / testimonials.length).toFixed(1)
  : '5.0';
---

<Layout title="Avis clients" description="Les retours de vendeurs et acquéreurs accompagnés par Mickael Gury et Marion Roulier en Auxois-Morvan." currentPage="/avis">

  <section class="section">
    <div class="shell">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end lg:gap-14">
        <div>
          <p class="eyebrow">Avis clients</p>
          <h1 class="mt-6 display-1 balanced-text">Des retours fondés sur la qualité du suivi.</h1>
          <p class="mt-6 max-w-xl text-[1.02rem] leading-[1.8] text-[color:var(--color-muted)]">
            Chaque projet immobilier est singulier. Voici ce que disent celles et ceux que nous avons accompagnés en Auxois, Morvan et plus largement en Côte-d'Or.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-3">
          <div class="surface-warm rounded-[1.5rem] p-6">
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Note moyenne</p>
            <p class="mt-3 stat-number">{averageRating}<span class="text-[color:var(--color-warm)]">★</span></p>
          </div>
          <div class="surface-accent rounded-[1.5rem] p-6">
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Témoignages</p>
            <p class="mt-3 stat-number">{testimonials.length}</p>
          </div>
          <div class="surface-soft rounded-[1.5rem] p-6">
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Secteur</p>
            <p class="mt-3 font-[family-name:var(--font-display)] text-[1.6rem] leading-tight text-[color:var(--color-ink-strong)]">{siteSettings.mainCity}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      {testimonials.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {testimonials.map((t, i) => (
            <TestimonialCard
              quote={t.quote}
              author={t.data.name}
              title={t.data.propertyType}
              location={t.data.location}
              rating={t.data.rating}
              variant={cardVariant(i)}
            />
          ))}
        </div>
      ) : (
        <div class="surface-soft rounded-[1.5rem] p-10 text-center">
          <p class="text-[color:var(--color-muted)]">Les premiers témoignages seront bientôt publiés.</p>
        </div>
      )}
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title="Et si on parlait de votre projet ?"
        description="<p>Vendre, acheter, faire estimer : un échange clair pour démarrer, c'est souvent le plus utile.</p>"
        primaryButtonText="Prendre contact"
        primaryButtonHref="/contact"
        secondaryButtonText="Faire estimer un bien"
        secondaryButtonHref="/estimation"
      />
    </div>
  </section>
</Layout>
