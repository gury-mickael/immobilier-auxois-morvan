---
import Layout from '../layouts/Layout.astro';
import ContentSections from '../components/ContentSections.astro';
import ContactBlock from '../components/ContactBlock.astro';
import CTASection from '../components/CTASection.astro';
import { getPageContent, getSiteSettings, resolveAssetSrc } from '../lib/content';

const [page, siteSettings] = await Promise.all([getPageContent('contact'), getSiteSettings()]);

const heroImage = resolveAssetSrc(page.data.heroImage);
---

<Layout title={page.data.title} description={page.data.metaDescription} currentPage="/contact" image={heroImage}>
  <section class="section bg-[radial-gradient(circle_at_18%_0%,rgba(22,101,138,0.14),transparent_32%),linear-gradient(180deg,#f7f9fb_0%,#ffffff_72%)] pt-10">
    <div class="shell">
      <ContactBlock
        phone={siteSettings.phone}
        email={siteSettings.email}
        coveredAreas={siteSettings.coveredAreas}
        mickaelName={siteSettings.mickaelName}
        marionName={siteSettings.marionName}
        mickaelPhoto={siteSettings.mickaelPhoto}
        marionPhoto={siteSettings.marionPhoto}
      />
    </div>
  </section>

  <ContentSections intro={page.data.intro} introEyebrow="Échange" introTitle="Un premier contact simple et professionnel" sections={page.data.sections} />

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title={page.data.ctaTitle}
        description={page.data.ctaText}
        primaryButtonText={page.data.ctaButtonLabel}
        primaryButtonHref={page.data.ctaButtonUrl}
        secondaryButtonText="Découvrir notre secteur"
        secondaryButtonHref="/secteur"
      />
    </div>
  </section>
</Layout>
