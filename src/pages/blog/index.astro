---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BlogCard from '../../components/BlogCard.astro';
import CTASection from '../../components/CTASection.astro';
import { formatLongDate, getPublishedBlogPosts, resolveAssetSrc } from '../../lib/content';

const blogPosts = await getPublishedBlogPosts();
const categories = [...new Set(blogPosts.map((post) => post.data.category))];
const blogHeroImage = '/uploads/our-experience.jpg';
const blogHeroImageAlt = 'Maison en pierre typique de l’Auxois Morvan';
---

<Layout
  title="Blog immobilier"
  description="Conseils, analyses et guides immobiliers pour vendre, acheter, estimer un bien ou préparer une cession de fonds de commerce en Auxois et Morvan."
  currentPage="/blog"
>
  <Hero
    eyebrow="Conseils et analyses"
    title="Blog immobilier de l'Auxois Morvan"
    subtitle="Des articles sobres, lisibles et utiles pour comprendre le marché, préparer une vente et avancer dans votre projet immobilier en Auxois et dans le Morvan."
    image={blogHeroImage}
    imageAlt={blogHeroImageAlt}
    stats={[
      { value: String(blogPosts.length), label: 'Articles publiés' },
      { value: categories.join(' · '), label: 'Thématiques' },
      { value: 'Local', label: 'Angle éditorial' },
      { value: 'Pratique', label: 'Contenu orienté action' }
    ]}
  />

  <section class="section pt-0">
    <div class="shell">
      <SectionHeader eyebrow="Articles" title="Les derniers contenus publiés" subtitle="Chaque article est alimenté depuis la collection blog, prêt à être enrichi ensuite depuis un CMS GitHub." />
      <div class="mt-10 grid gap-6">
        {blogPosts.map((post) => (
          <BlogCard
            title={post.data.displayTitle ?? post.data.title}
            excerpt={post.data.excerpt}
            href={`/blog/${post.data.slug}`}
            category={post.data.category}
            date={formatLongDate(post.data.date)}
            image={resolveAssetSrc(post.data.featuredImage)}
            imageAlt={post.data.featuredImageAlt}
            layout="row"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title="Une question après lecture ?"
        description="Nous pouvons prolonger ces conseils par un échange concret sur votre bien, votre secteur et votre calendrier."
        primaryButtonText="Nous contacter"
        primaryButtonHref="/contact"
        secondaryButtonText="Demander une estimation"
        secondaryButtonHref="/estimation"
      />
    </div>
  </section>
</Layout>
