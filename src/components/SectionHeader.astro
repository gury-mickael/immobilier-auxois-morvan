---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  size?: 'md' | 'lg';
}

import RichTextContent from './RichTextContent.astro';

const { eyebrow, title, subtitle, align = 'left', size = 'md' } = Astro.props;
const centered = align === 'center';
const titleSize =
  size === 'lg'
    ? 'display-1'
    : 'display-2';
---

<div class={`${centered ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}`}>
  {eyebrow && <p class={`eyebrow ${centered ? 'justify-center' : ''}`}>{eyebrow}</p>}
  <h2 class={`mt-5 ${titleSize}`}>{title}</h2>
  {subtitle && <RichTextContent html={subtitle} className={`mt-5 text-[1rem] leading-[1.75] text-[color:var(--color-muted)] md:text-[1.05rem] ${centered ? 'mx-auto' : ''}`} />}
</div>
