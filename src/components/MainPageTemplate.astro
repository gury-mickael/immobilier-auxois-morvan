---
import Layout from '../layouts/Layout.astro';
import Hero from './Hero.astro';
import ContentSections from './ContentSections.astro';
import CTASection from './CTASection.astro';
import { resolveAssetSrc } from '../lib/content';

interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
}

interface Stat {
  label: string;
  value: string;
}

interface Props {
  page: {
    data: {
      title: string;
      metaDescription: string;
      h1: string;
      heroTitle: string;
      heroSubtitle: string;
      heroImage?: string | { src: string };
      heroImageAlt?: string;
      intro: string;
      sections: {
        eyebrow?: string;
        title: string;
        text: string;
        image?: string;
        imageAlt?: string;
        buttonLabel?: string;
        buttonUrl?: string;
        items?: string[];
        stats?: { label: string; value: string }[];
      }[];
      ctaTitle: string;
      ctaText: string;
      ctaButtonLabel: string;
      ctaButtonUrl: string;
    };
  };
  currentPage: string;
  eyebrow?: string;
  actions?: Action[];
  stats?: Stat[];
  introEyebrow?: string;
  introTitle?: string;
}

const {
  page,
  currentPage,
  eyebrow = 'Conseil immobilier local',
  actions,
  stats = [],
  introEyebrow,
  introTitle
} = Astro.props;

const heroImage = resolveAssetSrc(page.data.heroImage);
const heroActions =
  actions ??
  [
    { label: page.data.ctaButtonLabel, href: page.data.ctaButtonUrl, variant: 'primary' as const },
    {
      label: page.data.ctaButtonUrl === '/contact' ? 'Demander une estimation' : 'Nous contacter',
      href: page.data.ctaButtonUrl === '/contact' ? '/estimation' : '/contact',
      variant: 'outline' as const
    }
  ];
---

<Layout title={page.data.title} description={page.data.metaDescription} currentPage={currentPage} image={heroImage}>
  <Hero eyebrow={eyebrow} title={page.data.heroTitle} subtitle={page.data.heroSubtitle} actions={heroActions} stats={stats} image={heroImage} imageAlt={page.data.heroImageAlt} />

  <ContentSections intro={page.data.intro} introEyebrow={introEyebrow} introTitle={introTitle} sections={page.data.sections} />

  <slot />

  <section class="section pt-0">
    <div class="shell">
      <CTASection
        title={page.data.ctaTitle}
        description={page.data.ctaText}
        primaryButtonText={page.data.ctaButtonLabel}
        primaryButtonHref={page.data.ctaButtonUrl}
        secondaryButtonText={page.data.ctaButtonUrl === '/contact' ? 'Demander une estimation' : 'Nous contacter'}
        secondaryButtonHref={page.data.ctaButtonUrl === '/contact' ? '/estimation' : '/contact'}
      />
    </div>
  </section>
</Layout>