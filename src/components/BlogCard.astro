---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  category: string;
  date: string;
  image?: string;
  imageAlt?: string;
  layout?: 'grid' | 'row';
}

const { title, excerpt, href, category, date, image, imageAlt, layout = 'grid' } = Astro.props;
const isRow = layout === 'row';
---

<article class={`group overflow-hidden rounded-[1.25rem] border border-[color:var(--color-border)] bg-white ${isRow ? 'shadow-none' : ''}`}>
  <a href={href} class="block">
    <div class={isRow ? 'md:grid md:grid-cols-[19rem_1fr] md:items-stretch' : ''}>
      {image && <img src={image} alt={imageAlt ?? title} class={isRow ? 'h-64 w-full object-cover md:h-full' : 'h-60 w-full object-cover'} loading="lazy" decoding="async" />}
      <div class={isRow ? 'p-7 md:p-8' : 'p-7'}>
      <div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-[color:var(--color-muted)]">
        <span>{category}</span>
        <span class="h-1 w-1 rounded-full bg-[color:var(--color-border-strong)]"></span>
        <span>{date}</span>
      </div>
      <h3 class={`mt-4 leading-tight transition-colors duration-200 group-hover:text-[color:var(--color-accent-strong)] ${isRow ? 'text-[1.6rem] md:text-[2rem]' : 'text-[1.9rem]'}`}>
        {title}
      </h3>
      <p class="mt-4 text-[0.98rem] leading-7 text-[color:var(--color-muted)]">{excerpt}</p>
      <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Lire l'article
        <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
      </span>
      </div>
    </div>
  </a>
</article>