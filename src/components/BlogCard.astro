---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  category: string;
  date: string;
  image?: string;
  imageAlt?: string;
  layout?: 'grid' | 'row';
}

const { title, excerpt, href, category, date, image, imageAlt, layout = 'grid' } = Astro.props;
const isRow = layout === 'row';
---

<article class={`group overflow-hidden rounded-[1.5rem] bg-[color:var(--color-bg-soft)] lift ${isRow ? '' : ''}`}>
  <a href={href} class="block">
    <div class={isRow ? 'md:grid md:grid-cols-[20rem_1fr] md:items-stretch' : ''}>
      <div class={`zoom-img overflow-hidden bg-[color:var(--color-bg-warm)] ${isRow ? 'aspect-[4/3] md:aspect-auto md:h-full' : 'aspect-[4/3]'}`}>
        {image && <img src={image} alt={imageAlt ?? title} class="h-full w-full object-cover" loading="lazy" decoding="async" />}
      </div>
      <div class={isRow ? 'p-6 md:p-9' : 'p-6 md:p-7'}>
        <div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[color:var(--color-muted)]">
          <span>{category}</span>
          <span class="h-1 w-1 rounded-full bg-[color:var(--color-muted-soft)]"></span>
          <span>{date}</span>
        </div>
        <h3 class={`mt-4 font-[family-name:var(--font-display)] leading-[1.1] text-[color:var(--color-ink-strong)] transition-colors duration-300 group-hover:text-[color:var(--color-accent-strong)] ${isRow ? 'text-[1.6rem] md:text-[2rem]' : 'text-[1.45rem] md:text-[1.7rem]'}`}>
          {title}
        </h3>
        <p class="mt-4 text-[0.95rem] leading-7 text-[color:var(--color-muted)] line-clamp-3">{excerpt}</p>
        <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)]">
          Lire l'article
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </div>
    </div>
  </a>
</article>
