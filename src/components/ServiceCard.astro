---
interface Props {
  title: string;
  description: string;
  features?: string[];
  href?: string;
  kicker?: string;
  index?: number;
}

const { title, description, features, href, kicker = 'Service', index = 1 } = Astro.props;
const visibleFeatures = features?.slice(0, 3) ?? [];
const TagName = href ? 'a' : 'div';
---

<TagName
  href={href}
  class={`group relative flex h-full flex-col overflow-hidden rounded-[1.5rem] bg-[color:var(--color-bg-soft)] p-7 md:p-9 lift transition-colors duration-300 ${href ? 'hover:bg-[color:var(--color-accent-soft)]' : ''}`}
>
  <span class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-[color:var(--color-muted)]">{String(index).padStart(2, '0')} · {kicker}</span>
  <h3 class="mt-5 font-[family-name:var(--font-display)] text-[1.85rem] leading-[1.05] text-[color:var(--color-ink-strong)] md:text-[2.1rem]">
    {title}
  </h3>
  <p class="mt-4 text-[0.95rem] leading-7 text-[color:var(--color-muted)] md:text-[0.98rem]">
    {description}
  </p>
  {visibleFeatures.length > 0 && (
    <ul class="mt-6 grid gap-2.5">
      {visibleFeatures.map((feature) => (
        <li class="flex items-start gap-3 text-[0.9rem] text-[color:var(--color-ink)]">
          <svg class="mt-1 h-3.5 w-3.5 flex-shrink-0 text-[color:var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}
  {href && (
    <span class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)]">
      Découvrir
      <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </span>
  )}
</TagName>
