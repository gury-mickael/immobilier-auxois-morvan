---
interface Props {
  title: string;
  description: string;
  features?: string[];
  href?: string;
  kicker?: string;
}

const { title, description, features, href, kicker = 'Service' } = Astro.props;
const TagName = href ? 'a' : 'div';
---

<TagName
  href={href}
  class={`group flex h-full flex-col rounded-[1.25rem] border border-[color:var(--color-border)] bg-white p-8 ${href ? 'hover:border-[color:var(--color-accent)]' : ''}`}
>
  <p class="eyebrow mb-5">{kicker}</p>
  <h3 class="text-[2rem] leading-tight text-[color:var(--color-ink-strong)]">
    {title}
  </h3>
  <p class="mt-4 text-[0.98rem] leading-7 text-[color:var(--color-muted)]">
    {description}
  </p>
  {features && features.length > 0 && (
    <ul class="mt-6 grid gap-3">
      {features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-[color:var(--color-ink)]">
          <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent)]"></span>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}
  {href && (
    <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
      En savoir plus
      <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
    </span>
  )}
</TagName>
