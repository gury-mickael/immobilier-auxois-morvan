---
interface Props {
  quote: string;
  author: string;
  title?: string;
  rating?: number;
}

const { quote, author, title, rating = 5 } = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div class="bg-white rounded-xl p-8 shadow-md border border-slate-100 h-full flex flex-col">
  <div class="flex gap-1 mb-4">
    {stars.map((filled) => (
      <span class={`text-xl ${filled ? 'text-amber-400' : 'text-slate-300'}`}>
        ★
      </span>
    ))}
  </div>
  <p class="text-slate-700 mb-6 flex-grow italic">
    "{quote}"
  </p>
  <div>
    <p class="font-semibold text-slate-900">
      {author}
    </p>
    {title && (
      <p class="text-sm text-slate-600">
        {title}
      </p>
    )}
  </div>
</div>
