---
interface Props {
  quote: string;
  author: string;
  title?: string;
  rating?: number;
  location?: string;
  variant?: 'soft' | 'warm' | 'panel';
}

const { quote, author, title, rating = 5, location, variant = 'soft' } = Astro.props;

const variantClass = {
  soft: 'bg-[color:var(--color-bg-soft)]',
  warm: 'bg-[color:var(--color-warm-soft)]',
  panel: 'bg-white'
}[variant];

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
const authorInitial = author.charAt(0).toUpperCase();
---

<article class={`flex h-full flex-col rounded-[1.5rem] p-7 md:p-9 ${variantClass}`}>
  <svg class="h-8 w-8 text-[color:var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M9.5 4C5 4 2 7.5 2 12.5V20h7.5v-7.5H6c0-3 1.5-5 3.5-5V4ZM21.5 4c-4.5 0-7.5 3.5-7.5 8.5V20h7.5v-7.5H18c0-3 1.5-5 3.5-5V4Z"/>
  </svg>
  <p class="mt-5 font-[family-name:var(--font-display)] text-[1.25rem] leading-[1.55] text-[color:var(--color-ink-strong)] md:text-[1.4rem] md:leading-[1.5]">
    {quote}
  </p>
  <div class="mt-auto pt-7 flex items-center gap-4">
    <div class="h-12 w-12 flex-shrink-0 rounded-full bg-[color:var(--color-accent-soft)] flex items-center justify-center font-[family-name:var(--font-display)] text-lg font-semibold text-[color:var(--color-accent-strong)]">
      {authorInitial}
    </div>
    <div class="min-w-0">
      <p class="font-semibold text-[color:var(--color-ink-strong)]">{author}</p>
      <p class="text-sm text-[color:var(--color-muted)] truncate">{[title, location].filter(Boolean).join(' · ')}</p>
    </div>
    <div class="ml-auto flex gap-0.5">
      {stars.map((filled) => (
        <svg class={`h-3.5 w-3.5 ${filled ? 'text-[color:var(--color-warm)]' : 'text-[color:var(--color-muted-soft)]'}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
  </div>
</article>
