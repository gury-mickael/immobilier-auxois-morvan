---
interface Props {
  quote: string;
  author: string;
  title?: string;
  rating?: number;
  location?: string;
}

const { quote, author, title, rating = 5, location } = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<article class="flex h-full flex-col rounded-[1.75rem] border border-[color:var(--color-border)] bg-white/88 p-8 shadow-[0_18px_36px_rgba(24,37,45,0.06)]">
  <div class="flex gap-2">
    {stars.map((filled) => (
      <span class={`h-2.5 w-2.5 rounded-full ${filled ? 'bg-[color:var(--color-accent)]' : 'bg-[rgba(24,37,45,0.12)]'}`}></span>
    ))}
  </div>
  <p class="mt-6 flex-grow text-[1.02rem] leading-8 text-[color:var(--color-ink)]">
    “{quote}”
  </p>
  <div class="mt-6 border-t border-[color:var(--color-border)] pt-5">
    <p class="text-lg font-semibold text-[color:var(--color-ink-strong)]">
      {author}
    </p>
    <p class="text-sm text-[color:var(--color-muted)]">{[title, location].filter(Boolean).join(' — ')}</p>
  </div>
</article>
