---
import Button from './Button.astro';
import RichTextContent from './RichTextContent.astro';

interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'light';
}

interface Stat {
  label: string;
  value: string;
}

interface Person {
  name: string;
  role?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  actions?: Action[];
  stats?: Stat[];
  image?: string;
  imageAlt?: string;
  people?: Person[];
  variant?: 'home' | 'page';
}

const {
  eyebrow,
  title,
  subtitle,
  actions = [],
  stats = [],
  image,
  imageAlt = 'Illustration',
  people = [],
  variant = 'page'
} = Astro.props;
---

{variant === 'home' ? (
  <section class="relative overflow-hidden pt-8 md:pt-14">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12 lg:items-end">
        <div class="reveal">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1 class="mt-6 display-1 balanced-text">{title}</h1>
          <RichTextContent html={subtitle} className="mt-6 max-w-xl text-[1rem] leading-[1.75] text-[color:var(--color-muted)] md:text-[1.08rem] md:leading-[1.8]" />
          {actions.length > 0 && (
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              {actions.map((action, index) => (
                <Button href={action.href} variant={action.variant ?? (index === 0 ? 'primary' : 'outline')} size="lg">
                  {action.label}
                </Button>
              ))}
            </div>
          )}
          {people.length > 0 && (
            <div class="mt-10 flex items-center gap-4">
              <div class="flex -space-x-3">
                {people.map((p) => (
                  p.image ? (
                    <img src={p.image} alt={p.imageAlt ?? p.name} class="h-12 w-12 rounded-full object-cover ring-4 ring-[color:var(--color-bg)]" loading="eager" decoding="async" />
                  ) : (
                    <div class="h-12 w-12 rounded-full bg-[color:var(--color-accent-soft)] ring-4 ring-[color:var(--color-bg)] flex items-center justify-center font-semibold text-[color:var(--color-accent-strong)]">
                      {p.name.charAt(0)}
                    </div>
                  )
                ))}
              </div>
              <div class="text-sm leading-tight">
                <p class="font-medium text-[color:var(--color-ink-strong)]">{people.map((p) => p.name).join(' & ')}</p>
                <p class="text-[color:var(--color-muted)]">Vos conseillers locaux</p>
              </div>
            </div>
          )}
        </div>

        <div class="reveal relative">
          <div class="zoom-img relative aspect-[4/5] w-full overflow-hidden rounded-[2rem] bg-[color:var(--color-bg-warm)]">
            {image ? (
              <img src={image} alt={imageAlt} class="h-full w-full object-cover" loading="eager" decoding="async" />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-[color:var(--color-muted)]">Auxois · Morvan</div>
            )}
          </div>
          {stats.length > 0 && (
            <div class="absolute -bottom-6 -left-3 max-w-[18rem] rounded-2xl bg-white p-5 md:-left-6 md:-bottom-8 md:p-6">
              <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-muted)]">{stats[0].label}</p>
              <p class="mt-2 stat-number">{stats[0].value}</p>
            </div>
          )}
          {stats.length > 1 && (
            <div class="absolute -top-4 -right-2 hidden rounded-2xl bg-[color:var(--color-dark)] p-5 text-white md:block md:-top-8 md:-right-6 md:p-6">
              <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-white/60">{stats[1].label}</p>
              <p class="mt-2 stat-number text-white">{stats[1].value}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="section-lg">
    <div class="shell">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:gap-12">
        <div>
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1 class="mt-5 display-2 balanced-text">{title}</h1>
          <RichTextContent html={subtitle} className="mt-5 max-w-2xl text-[1rem] leading-[1.75] text-[color:var(--color-muted)] md:text-[1.05rem]" />
          {actions.length > 0 && (
            <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              {actions.map((action, index) => (
                <Button href={action.href} variant={action.variant ?? (index === 0 ? 'primary' : 'outline')} size="lg">
                  {action.label}
                </Button>
              ))}
            </div>
          )}
        </div>
        <div class="zoom-img relative aspect-[4/3] w-full overflow-hidden rounded-[1.75rem] bg-[color:var(--color-bg-soft)]">
          {image && <img src={image} alt={imageAlt} class="h-full w-full object-cover" loading="eager" decoding="async" />}
        </div>
      </div>
    </div>
  </section>
)}
