---
import Button from './Button.astro';
import RichTextContent from './RichTextContent.astro';

interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
}

interface Stat {
  label: string;
  value: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  actions?: Action[];
  stats?: Stat[];
  image?: string;
  imageAlt?: string;
}

const { eyebrow, title, subtitle, actions = [], stats = [], image, imageAlt = 'Illustration de la page' } = Astro.props;
---

<section class="section section-lg">
  <div class="shell">
    <div class="grid gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:items-start">
      <div class="max-w-3xl">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1 class="balanced-text mt-6 text-4xl leading-[0.95] md:text-6xl xl:text-[4.45rem]">{title}</h1>
        <RichTextContent html={subtitle} className="mt-6 max-w-2xl text-[1rem] leading-8 text-[color:var(--color-muted)] md:text-[1.08rem]" />
        {actions.length > 0 && (
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {actions.map((action, index) => (
              <Button href={action.href} variant={action.variant ?? (index === 0 ? 'primary' : 'outline')} size="lg">
                {action.label}
              </Button>
            ))}
          </div>
        )}
      </div>

      <div class="grid gap-5">
        <div class="overflow-hidden rounded-[1.75rem] border border-[color:var(--color-border)] bg-[color:var(--color-bg-soft)]">
          {image ? (
            <img src={image} alt={imageAlt} class="h-[360px] w-full object-cover" loading="eager" decoding="async" />
          ) : (
            <div class="flex h-[360px] items-center justify-center px-8 text-center text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--color-muted)]">
              Auxois · Morvan · Immobilier local
            </div>
          )}
        </div>

        <div class="grid gap-px rounded-[1.25rem] border border-[color:var(--color-border)] bg-[color:var(--color-border)] sm:grid-cols-2">
          {(stats.length > 0
            ? stats
            : [
                { value: 'Auxois', label: 'Territoire suivi' },
                { value: 'Morvan', label: 'Projet de vie' },
                { value: 'IAD', label: 'Réseau national' },
                { value: 'Sur mesure', label: 'Accompagnement' }
              ]).map((stat) => (
            <div class="bg-white px-5 py-5">
              <p class="text-[1.45rem] font-extrabold text-[color:var(--color-ink-strong)]">{stat.value}</p>
              <p class="mt-1 text-sm text-[color:var(--color-muted)]">{stat.label}</p>
            </div>
          ))}
          </div>
        </div>
        <slot name="aside" />
      </div>
    </div>
  </div>
</section>