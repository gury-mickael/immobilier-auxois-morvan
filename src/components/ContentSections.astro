---
import SectionHeader from './SectionHeader.astro';
import RichTextContent from './RichTextContent.astro';

interface SectionStat {
  label: string;
  value: string;
}

interface SectionItem {
  eyebrow?: string;
  title: string;
  text: string;
  image?: string;
  imageAlt?: string;
  buttonLabel?: string;
  buttonUrl?: string;
  items?: string[];
  stats?: SectionStat[];
}

interface Props {
  intro?: string;
  introEyebrow?: string;
  introTitle?: string;
  sections: SectionItem[];
}

const {
  intro,
  introEyebrow = 'Introduction',
  introTitle = 'Une approche claire et structurée',
  sections
} = Astro.props;

const formatIndex = (index: number) => String(index + 1).padStart(2, '0');
---

{intro && (
  <section class="section pt-0">
    <div class="shell">
      <div class="grid gap-8 border-t border-[color:var(--color-border)] pt-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <p class="eyebrow">{introEyebrow}</p>
        <div>
          <h2 class="text-4xl leading-tight md:text-5xl">{introTitle}</h2>
          <RichTextContent html={intro} className="mt-5 max-w-4xl text-[1.02rem] leading-8 text-[color:var(--color-muted)]" />
        </div>
      </div>
    </div>
  </section>
)}

<section class="section pt-0">
  <div class="shell grid gap-12 md:gap-14">
    {sections.map((section, index) => (
      <article class={`grid gap-8 border-t border-[color:var(--color-border)] pt-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start ${index % 2 === 1 ? 'lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1' : ''}`}>
        <div class="surface-muted rounded-[1.5rem] p-7 md:p-8">
          <div class="flex items-start justify-between gap-6 border-b border-[color:var(--color-border)] pb-6">
            <p class="text-3xl font-extrabold leading-none text-[color:var(--color-accent)] md:text-4xl">{formatIndex(index)}</p>
            {section.eyebrow && <p class="text-right text-[0.72rem] font-bold uppercase tracking-[0.16em] text-[color:var(--color-muted)]">{section.eyebrow}</p>}
          </div>

          {section.items && section.items.length > 0 && (
            <ul class="mt-6 grid gap-3">
              {section.items.map((item) => (
                <li class="flex items-start gap-3 text-sm leading-7 text-[color:var(--color-ink)]">
                  <span class="mt-3 h-1.5 w-8 rounded-full bg-[color:var(--color-accent)]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}

          {section.stats && section.stats.length > 0 && (
            <div class="mt-6 grid gap-px rounded-[1rem] border border-[color:var(--color-border)] bg-[color:var(--color-border)] sm:grid-cols-2">
              {section.stats.map((stat) => (
                <div class="bg-white px-5 py-4">
                  <p class="text-2xl font-extrabold text-[color:var(--color-ink-strong)]">{stat.value}</p>
                  <p class="mt-1 text-sm text-[color:var(--color-muted)]">{stat.label}</p>
                </div>
              ))}
            </div>
          )}

          {!section.items?.length && !section.stats?.length && (
            <div class="mt-6 rounded-[1rem] border border-[color:var(--color-border)] bg-white px-5 py-5 text-sm leading-7 text-[color:var(--color-muted)]">
              Accompagnement local, approche claire et suivi rigoureux sur chaque étape du projet.
            </div>
          )}

          {section.image && (
            <div class="mt-6 overflow-hidden rounded-[1rem] border border-[color:var(--color-border)] bg-white">
              <img src={section.image} alt={section.imageAlt ?? section.title} class="h-56 w-full object-cover" loading="lazy" decoding="async" />
            </div>
          )}
        </div>

        <div>
          <SectionHeader eyebrow={section.eyebrow} title={section.title} />
          <RichTextContent html={section.text} className="mt-6 max-w-3xl text-[1rem] leading-8 text-[color:var(--color-ink)]" />
          {section.buttonLabel && section.buttonUrl && (
            <a href={section.buttonUrl} class="mt-8 inline-flex rounded-full border border-[color:var(--color-accent)] bg-[color:var(--color-accent)] px-5 py-3 text-sm font-semibold text-white hover:border-[color:var(--color-accent-strong)] hover:bg-[color:var(--color-accent-strong)]">
              {section.buttonLabel}
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>