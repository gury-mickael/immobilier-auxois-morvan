---
interface Props {
  phone: string;
  email: string;
  coveredAreas: string[];
  mickaelName: string;
  marionName: string;
}

const { phone, email, coveredAreas, mickaelName, marionName } = Astro.props;
---

<section class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr]">
  <div class="surface-panel rounded-[1.5rem] p-8">
    <p class="eyebrow">Coordonnées</p>
    <h2 class="mt-5 text-4xl">Parler de votre projet</h2>
    <p class="mt-4 text-[0.98rem] leading-7 text-[color:var(--color-muted)]">
      {mickaelName} et {marionName} vous répondent pour vendre, acheter, faire estimer un bien ou préparer une cession de fonds de commerce.
    </p>

    <div class="mt-8 grid gap-4 text-sm text-[color:var(--color-ink)]">
      <a href={`tel:${phone.replace(/\s+/g, '')}`} class="surface-muted rounded-[1rem] px-5 py-4 font-semibold">
        {phone}
      </a>
      <a href={`mailto:${email}`} class="surface-muted rounded-[1rem] px-5 py-4 font-semibold break-all">
        {email}
      </a>
    </div>

    <div class="mt-8">
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-[color:var(--color-muted)]">Secteur couvert</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {coveredAreas.map((area) => (
          <span class="rounded-xl border border-[color:var(--color-border)] bg-white px-3 py-2 text-xs font-semibold text-[color:var(--color-ink)]">
            {area}
          </span>
        ))}
      </div>
    </div>
  </div>

  <form class="surface-panel rounded-[1.5rem] p-8 md:p-10" action="#" method="post">
    <div class="border-b border-[color:var(--color-border)] pb-6">
      <p class="eyebrow">Message</p>
      <h2 class="mt-5 text-3xl leading-tight md:text-4xl">Écrivez-nous et laissez-nous vous guider</h2>
      <p class="mt-4 max-w-2xl text-[0.98rem] leading-7 text-[color:var(--color-muted)]">
        Un premier échange suffit pour cadrer votre projet, votre secteur et la meilleure suite à donner.
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Votre projet
        <select class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="project" required>
          <option value="">Choisir</option>
          <option value="acheter">Acheter</option>
          <option value="vendre">Vendre</option>
          <option value="estimation">Faire une estimation</option>
          <option value="fonds">Fonds de commerce</option>
        </select>
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Localisation
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="location" placeholder="Arnay-le-Duc, Autun..." />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Objet
        <select class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="subject" required>
          <option value="">Choisir</option>
          <option value="rdv">Premier rendez-vous</option>
          <option value="estimation">Demande d'estimation</option>
          <option value="recherche">Recherche de bien</option>
          <option value="autre">Autre demande</option>
        </select>
      </label>
    </div>

    <div class="mt-5 grid gap-5 md:grid-cols-2">
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Nom
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="name" placeholder="Votre nom" required />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Email
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="email" name="email" placeholder="vous@exemple.fr" required />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Téléphone
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="tel" name="phone" placeholder="06 00 00 00 00" />
      </label>
    </div>

    <label class="mt-5 grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
      Message
      <textarea class="min-h-44 rounded-[1rem] border border-[color:var(--color-border)] bg-white px-4 py-3 font-medium text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="message" placeholder="Décrivez votre projet, votre secteur et votre calendrier." required></textarea>
    </label>

    <label class="mt-5 flex items-start gap-3 text-sm leading-6 text-[color:var(--color-muted)]">
      <input type="checkbox" name="privacy" required class="mt-1 h-4 w-4 rounded border-[color:var(--color-border)] text-[color:var(--color-accent)]" />
      <span>J'accepte d'être recontacté au sujet de ma demande. Ce formulaire reste purement côté front dans cette version du site.</span>
    </label>

    <button type="submit" class="mt-6 inline-flex rounded-xl border border-[color:var(--color-accent)] bg-[color:var(--color-accent)] px-6 py-3 text-sm font-semibold text-white hover:bg-[color:var(--color-accent-strong)] hover:border-[color:var(--color-accent-strong)]">
      Envoyer le message
    </button>
  </form>
</section>