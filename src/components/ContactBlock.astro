---
interface Props {
  phone: string;
  email: string;
  coveredAreas: string[];
  mickaelName: string;
  marionName: string;
  mickaelPhoto?: string;
  marionPhoto?: string;
}

const { phone, email, coveredAreas, mickaelName, marionName, mickaelPhoto, marionPhoto } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s+/g, '')}`;
---

<section class="grid gap-5 lg:grid-cols-[1.12fr_0.88fr] lg:items-start">
  <form class="surface-panel rounded-[2rem] p-6 shadow-[0_28px_80px_rgba(18,26,34,0.09)] md:p-10" action={`mailto:${email}`} method="post" enctype="text/plain">
    <div class="max-w-3xl">
      <p class="eyebrow">Contact direct</p>
      <h1 class="mt-5 max-w-[11ch] text-5xl leading-[0.96] tracking-[-0.06em] md:text-7xl">Parlons de votre projet immobilier</h1>
      <p class="mt-5 text-[1.03rem] leading-8 text-[color:var(--color-muted)]">
        Envoyez-nous les premières informations : secteur, calendrier, type de bien et objectif. Nous revenons vers vous avec une réponse claire et utile.
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Votre projet
        <select class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="project">
          <option value="">Choisir</option>
          <option value="acheter">Acheter</option>
          <option value="vendre">Vendre</option>
          <option value="estimation">Faire une estimation</option>
          <option value="fonds">Fonds de commerce</option>
        </select>
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Localisation
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="location" placeholder="Arnay-le-Duc, Autun..." />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Objet
        <select class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="subject" required>
          <option value="">Choisir</option>
          <option value="rdv">Premier rendez-vous</option>
          <option value="estimation">Demande d'estimation</option>
          <option value="recherche">Recherche de bien</option>
          <option value="autre">Autre demande</option>
        </select>
      </label>
    </div>

    <div class="mt-5 grid gap-5 md:grid-cols-2">
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Nom
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="text" name="name" placeholder="Votre nom" required />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Email
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="email" name="email" placeholder="vous@exemple.fr" required />
      </label>
      <label class="grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
        Téléphone
        <input class="rounded-xl border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" type="tel" name="phone" placeholder="07.64.86.59.93" />
      </label>
    </div>

    <label class="mt-5 grid gap-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">
      Message
      <textarea class="min-h-44 rounded-[1rem] border border-[color:var(--color-border)] bg-white px-4 py-3 font-semibold text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-accent)]" name="message" placeholder="Décrivez votre projet, votre secteur et votre calendrier." required></textarea>
    </label>

    <label class="mt-5 flex items-start gap-3 text-sm leading-6 text-[color:var(--color-muted)]">
      <input type="checkbox" name="privacy" required class="mt-1 h-4 w-4 rounded border-[color:var(--color-border)] text-[color:var(--color-accent)]" />
      <span>J'accepte d'être recontacté au sujet de ma demande.</span>
    </label>

    <button type="submit" class="mt-6 inline-flex rounded-full border border-[color:var(--color-accent)] bg-[color:var(--color-accent)] px-7 py-3.5 text-sm font-extrabold text-white hover:bg-[color:var(--color-accent-strong)] hover:border-[color:var(--color-accent-strong)]">
      Envoyer le message
    </button>
  </form>

  <aside class="grid gap-4">
    <div class="rounded-[1.6rem] bg-[linear-gradient(135deg,#14222b,#1b3f51)] p-7 text-white shadow-[0_28px_80px_rgba(18,26,34,0.12)]">
      <p class="eyebrow !text-white before:!bg-white/70">Réponse rapide</p>
      <h2 class="mt-5 text-4xl leading-tight !text-white">Une question ? Appelez-nous directement.</h2>
      <a href={phoneHref} class="mt-7 block text-4xl font-extrabold tracking-[-0.05em] md:text-5xl">{phone}</a>
      <a href={`mailto:${email}`} class="mt-3 block break-all font-extrabold text-white/75">{email}</a>
    </div>

    <div class="surface-panel grid grid-cols-2 gap-3 rounded-[1.6rem] p-4 shadow-[0_22px_60px_rgba(18,26,34,0.08)]">
      <div class="grid gap-3">
        {marionPhoto ? <img src={marionPhoto} alt={marionName} class="aspect-square w-full rounded-[1.15rem] object-cover" /> : <div class="grid aspect-square place-items-center rounded-[1.15rem] bg-[color:var(--color-bg-soft)] text-5xl font-extrabold text-[color:var(--color-accent)]">M</div>}
        <strong class="text-sm text-[color:var(--color-ink-strong)]">{marionName}</strong>
      </div>
      <div class="grid gap-3">
        {mickaelPhoto ? <img src={mickaelPhoto} alt={mickaelName} class="aspect-square w-full rounded-[1.15rem] object-cover" /> : <div class="grid aspect-square place-items-center rounded-[1.15rem] bg-[color:var(--color-bg-soft)] text-5xl font-extrabold text-[color:var(--color-accent)]">M</div>}
        <strong class="text-sm text-[color:var(--color-ink-strong)]">{mickaelName}</strong>
      </div>
    </div>

    <div class="surface-panel rounded-[1.6rem] p-7 shadow-[0_22px_60px_rgba(18,26,34,0.08)]">
      <h3 class="text-2xl">Ce que l’on prépare avec vous</h3>
      <ul class="mt-5 grid gap-3 text-sm font-semibold leading-7 text-[color:var(--color-ink)]">
        <li>• Une estimation claire et argumentée</li>
        <li>• Un plan de vente adapté au secteur</li>
        <li>• Une recherche qualifiée si vous achetez</li>
        <li>• Un rendez-vous simple, au téléphone ou sur place</li>
      </ul>
    </div>

    <div class="surface-panel rounded-[1.6rem] p-7 shadow-[0_22px_60px_rgba(18,26,34,0.08)]">
      <h3 class="text-2xl">Secteur couvert</h3>
      <div class="mt-4 flex flex-wrap gap-2">
        {coveredAreas.slice(0, 8).map((area) => (
          <span class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-soft)] px-3 py-2 text-xs font-extrabold text-[color:var(--color-ink-strong)]">
            {area}
          </span>
        ))}
      </div>
    </div>
  </aside>
</section>