---
interface Props {
  title: string;
  description?: string;
  primaryButtonText: string;
  primaryButtonHref: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
}

const {
  title,
  description,
  primaryButtonText,
  primaryButtonHref,
  secondaryButtonText,
  secondaryButtonHref
} = Astro.props;

import Button from './Button.astro';
---

<section class="surface-panel overflow-hidden rounded-[2rem] p-8 md:p-12">
  <div class="grid gap-8 lg:grid-cols-[1.3fr_auto] lg:items-end">
    <div>
      <p class="eyebrow">Projet immobilier</p>
      <h2 class="mt-5 text-4xl leading-tight md:text-5xl">
        {title}
      </h2>
  {description && (
        <p class="mt-4 max-w-2xl text-[1.02rem] leading-8 text-[color:var(--color-muted)]">
          {description}
        </p>
  )}
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
      <Button href={primaryButtonHref} variant="primary" size="lg">
        {primaryButtonText}
      </Button>
      {secondaryButtonText && secondaryButtonHref && (
        <Button href={secondaryButtonHref} variant="outline" size="lg">
          {secondaryButtonText}
        </Button>
      )}
    </div>
  </div>
</section>
