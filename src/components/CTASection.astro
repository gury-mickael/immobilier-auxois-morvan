---
import RichTextContent from './RichTextContent.astro';
import Button from './Button.astro';

interface Props {
  title: string;
  description?: string;
  primaryButtonText: string;
  primaryButtonHref: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  backgroundImage?: string;
}

const {
  title,
  description,
  primaryButtonText,
  primaryButtonHref,
  secondaryButtonText,
  secondaryButtonHref,
  backgroundImage = '/uploads/photo-IAD-fond.jpg'
} = Astro.props;
---

<section class="relative overflow-hidden rounded-[2rem] bg-[color:var(--color-dark)] p-8 md:p-14">
  <img src={backgroundImage} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-40" loading="lazy" decoding="async" />
  <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-dark)]/95 via-[color:var(--color-dark)]/80 to-[color:var(--color-accent-strong)]/70"></div>
  <div class="relative grid gap-8 lg:grid-cols-[1.4fr_auto] lg:items-end">
    <div>
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/60">Votre projet</p>
      <h2 class="mt-4 display-2 text-white">
        {title}
      </h2>
      {description && <RichTextContent html={description} className="mt-5 max-w-2xl text-[1rem] leading-[1.75] text-white/80 md:text-[1.05rem]" />}
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
      <Button href={primaryButtonHref} variant="light" size="lg" fullWidth>
        {primaryButtonText}
      </Button>
      {secondaryButtonText && secondaryButtonHref && (
        <Button href={secondaryButtonHref} variant="ghost" size="lg" fullWidth class="text-white hover:text-white/80">
          {secondaryButtonText}
        </Button>
      )}
    </div>
  </div>
</section>
