        <ul class="space-y-3">
          <li><a href="/secteur" class="text-slate-400 hover:text-white transition-colors">Toutes les zones</a></li>
          <li><a href="/secteur#autun" class="text-slate-400 hover:text-white transition-colors">Autun</a></li>
