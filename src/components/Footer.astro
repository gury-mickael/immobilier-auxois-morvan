          <a href="#" class="text-slate-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 002.856-3.51 10 10 0 01-2.856.85 5 5 0 002.19-2.758 10 10 0 01-3.15 1.205 5 5 0 00-8.592 4.56 14.17 14.17 0 01-10.3-5.22 5 5 0 001.548 6.676 5 5 0 01-2.26-.616v.06a5 5 0 004.013 4.905 5 5 0 01-2.25.086 5 5 0 004.614 3.48 10 10 0 01-6.223 2.146A14.17 14.17 0 0023 4.57z"></path></svg>
