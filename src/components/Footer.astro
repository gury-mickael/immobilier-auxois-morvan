---
import { getSiteSettings } from '../lib/content';

const siteSettings = await getSiteSettings();
const mainAreas = siteSettings.coveredAreas.slice(0, 6);
---

<footer class="mt-12 border-t border-[rgba(255,255,255,0.1)] bg-[color:var(--color-ink-strong)] text-[rgba(255,255,255,0.78)]">
  <div class="shell py-16">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_repeat(3,minmax(0,1fr))]">
      <div class="max-w-md">
        <p class="eyebrow text-[rgba(255,255,255,0.56)] before:bg-[linear-gradient(90deg,var(--color-accent),transparent)]">
          Immobilier local
        </p>
        <h2 class="mt-6 text-3xl text-white">{siteSettings.siteName}</h2>
        <p class="mt-4 text-sm leading-7 text-[rgba(255,255,255,0.7)]">
          {siteSettings.shortPresentation}
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {(['linkedin', 'facebook', 'instagram'] as const).map((network) => (
            <a
              href={siteSettings.socialLinks[network]}
              class="rounded-full border border-[rgba(255,255,255,0.14)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-[rgba(255,255,255,0.72)] hover:border-[color:var(--color-accent)] hover:text-white"
            >
              {network}
            </a>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-white">Services</h3>
        <ul class="mt-5 space-y-3 text-sm">
          <li><a href="/vendre" class="hover:text-white">Vendre</a></li>
          <li><a href="/acheter" class="hover:text-white">Acheter</a></li>
          <li><a href="/estimation" class="hover:text-white">Estimation</a></li>
          <li><a href="/fonds" class="hover:text-white">Fonds de commerce</a></li>
          <li><a href="/blog" class="hover:text-white">Blog</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-white">Secteur</h3>
        <ul class="mt-5 space-y-3 text-sm">
          {mainAreas.map((area) => (
            <li>{area}</li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-white">Contact</h3>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href={`tel:${siteSettings.phone.replace(/\s+/g, '')}`} class="hover:text-white">
              {siteSettings.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteSettings.email}`} class="break-all hover:text-white">
              {siteSettings.email}
            </a>
          </li>
          <li>{siteSettings.primaryCity}</li>
          <li>
            <a href="/contact" class="inline-flex rounded-full border border-[rgba(255,255,255,0.18)] px-4 py-2 font-semibold text-white hover:border-[color:var(--color-accent)]">
              Demander un rendez-vous
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-[rgba(255,255,255,0.1)] pt-6 text-sm text-[rgba(255,255,255,0.56)] md:flex-row md:items-center md:justify-between">
      <p>{siteSettings.footer.copyright}</p>
      <div class="flex flex-wrap gap-4">
        <a href={siteSettings.footer.termsUrl} class="hover:text-white">{siteSettings.footer.termsLabel}</a>
        <a href={siteSettings.footer.privacyUrl} class="hover:text-white">{siteSettings.footer.privacyLabel}</a>
      </div>
    </div>
  </div>
</footer>
