---
import { getSiteSettings } from '../lib/content';
import BrandLogo from './BrandLogo.astro';

const siteSettings = await getSiteSettings();
const year = new Date().getFullYear();

const navColumns = [
  {
    title: 'Le cabinet',
    links: [
      { label: 'Notre histoire', href: '/histoire' },
      { label: 'Avis clients', href: '/avis' },
      { label: 'Contact', href: '/contact' }
    ]
  },
  {
    title: 'Prestations',
    links: [
      { label: 'Vendre un bien', href: '/vendre' },
      { label: 'Acheter', href: '/acheter' },
      { label: 'Estimation', href: '/estimation' },
      { label: 'Fonds de commerce', href: '/fonds' }
    ]
  },
  {
    title: 'Ressources',
    links: [
      { label: 'Notre secteur', href: '/secteur' },
      { label: 'Toutes nos prestations', href: '/prestations' },
      { label: 'Blog & conseils', href: '/blog' }
    ]
  }
];
---

<footer class="section-lg surface-dark mt-16 rounded-t-[2.5rem]">
  <div class="shell">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_2fr]">
      <div>
        <div class="bg-white inline-flex rounded-2xl p-3">
          <BrandLogo compact />
        </div>
        <p class="mt-6 max-w-md text-[0.98rem] leading-7 text-white/70">
          {siteSettings.footerText}
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          {siteSettings.facebookUrl && (
            <a href={siteSettings.facebookUrl} target="_blank" rel="noopener" class="chip chip-dark bg-white/10 text-white hover:bg-white/20">Facebook</a>
          )}
          {siteSettings.instagramUrl && (
            <a href={siteSettings.instagramUrl} target="_blank" rel="noopener" class="chip chip-dark bg-white/10 text-white hover:bg-white/20">Instagram</a>
          )}
          {siteSettings.iadUrl && (
            <a href={siteSettings.iadUrl} target="_blank" rel="noopener" class="chip chip-dark bg-white/10 text-white hover:bg-white/20">Réseau IAD</a>
          )}
        </div>
      </div>

      <div class="grid gap-10 sm:grid-cols-3">
        {navColumns.map((col) => (
          <div>
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/50">{col.title}</p>
            <ul class="mt-5 grid gap-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-[0.95rem] text-white/85 hover:text-white">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-14 grid gap-6 rounded-[1.5rem] bg-white/5 p-6 md:grid-cols-3 md:p-8">
      <div>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/50">Téléphone</p>
        <a href={`tel:${siteSettings.phone.replace(/\./g, '')}`} class="mt-3 block font-[family-name:var(--font-display)] text-2xl text-white">{siteSettings.phone}</a>
      </div>
      <div>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/50">Email</p>
        <a href={`mailto:${siteSettings.email}`} class="mt-3 block break-all font-[family-name:var(--font-display)] text-2xl text-white">{siteSettings.email}</a>
      </div>
      <div>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/50">Secteur</p>
        <p class="mt-3 font-[family-name:var(--font-display)] text-2xl text-white">{siteSettings.mainCity}</p>
        <p class="mt-1 text-sm text-white/60">Auxois · Morvan · Côte-d'Or</p>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 text-sm text-white/55 md:flex-row md:items-center md:justify-between">
      <p>© {year} {siteSettings.siteName}. Tous droits réservés.</p>
      <p>Conseillers immobiliers indépendants — Réseau IAD France</p>
    </div>
  </div>
</footer>
