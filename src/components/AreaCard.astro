---
interface Props {
  title: string;
  description: string;
  image?: string;
  href?: string;
}

const { title, description, image, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag href={href} class="group block h-full overflow-hidden rounded-[1.5rem] bg-[color:var(--color-bg-soft)] lift">
  <div class="zoom-img relative aspect-[4/3] w-full overflow-hidden bg-[color:var(--color-bg-warm)]">
    {image && <img src={image} alt={title} class="h-full w-full object-cover" loading="lazy" decoding="async" />}
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
    <span class="absolute bottom-4 left-4 rounded-full bg-white/95 px-3.5 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink-strong)]">
      {title}
    </span>
  </div>
  <div class="p-6 md:p-7">
    <p class="text-sm leading-7 text-[color:var(--color-muted)]">{description}</p>
  </div>
</Tag>
