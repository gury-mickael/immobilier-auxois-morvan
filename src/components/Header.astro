---
import BrandLogo from './BrandLogo.astro';
import Button from './Button.astro';
import { getSiteSettings } from '../lib/content';

interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;
const siteSettings = await getSiteSettings();

const navLinks = [
  { label: 'Accueil', href: '/' },
  { label: 'Histoire', href: '/histoire' },
  { label: 'Prestations', href: '/prestations' },
  { label: 'Secteur', href: '/secteur' },
  { label: 'Avis', href: '/avis' },
  { label: 'Blog', href: '/blog' }
];

const isActive = (href: string) => {
  if (href === '/') return currentPage === '/';
  return currentPage === href || currentPage.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-50 bg-[color:var(--color-bg)]/85 backdrop-blur-xl">
  <div class="shell flex items-center justify-between gap-4 py-4 md:py-5">
    <a href="/" class="inline-flex items-center" aria-label="Accueil">
      <BrandLogo compact />
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3.5 py-2 rounded-full text-[0.92rem] font-medium tracking-tight transition-colors',
            isActive(link.href)
              ? 'bg-[color:var(--color-ink-strong)] text-white'
              : 'text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-strong)]'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      {siteSettings.phone && (
        <a href={`tel:${siteSettings.phone.replace(/\./g, '')}`} class="text-[0.92rem] font-medium text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]">
          {siteSettings.phone}
        </a>
      )}
      <Button href="/contact" variant="primary" size="md">Contact</Button>
    </div>

    <button
      id="mobile-menu-btn"
      class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full bg-[color:var(--color-bg-soft)] text-[color:var(--color-ink-strong)]"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden">
    <div class="shell pb-6">
      <nav class="surface-soft rounded-[1.5rem] p-3" aria-label="Navigation mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'flex items-center justify-between rounded-2xl px-4 py-3.5 text-[1rem] font-medium',
              isActive(link.href)
                ? 'bg-[color:var(--color-ink-strong)] text-white'
                : 'text-[color:var(--color-ink-strong)] hover:bg-white'
            ]}
          >
            <span>{link.label}</span>
            <svg class="h-4 w-4 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 6l6 6-6 6" /></svg>
          </a>
        ))}
        <a href="/contact" class="mt-2 flex items-center justify-center rounded-2xl bg-[color:var(--color-accent)] px-4 py-3.5 text-[1rem] font-semibold text-white">
          Nous contacter
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
