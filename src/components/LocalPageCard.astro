---
interface Props {
  title: string;
  city: string;
  pageType: string;
  href: string;
  excerpt: string;
  image?: string;
}

const { title, city, pageType, href, excerpt, image } = Astro.props;
---

<a href={href} class="group flex h-full flex-col overflow-hidden rounded-[1.5rem] bg-[color:var(--color-bg-soft)] lift">
  <div class="zoom-img aspect-[4/3] w-full overflow-hidden bg-[color:var(--color-bg-warm)]">
    {image && <img src={image} alt={title} class="h-full w-full object-cover" loading="lazy" decoding="async" />}
  </div>
  <div class="flex flex-1 flex-col p-6 md:p-7">
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-accent)]">{pageType.replaceAll('-', ' ')} · {city}</p>
    <h3 class="mt-3 font-[family-name:var(--font-display)] text-[1.4rem] leading-[1.15] text-[color:var(--color-ink-strong)] md:text-[1.6rem]">{title}</h3>
    <p class="mt-3 text-sm leading-7 text-[color:var(--color-muted)] line-clamp-3">{excerpt}</p>
    <span class="mt-auto pt-5 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-ink-strong)]">
      Voir la page
      <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </span>
  </div>
</a>
