---
interface Props {
  title: string;
  text: string;
  items?: string[];
}

const { title, text, items = [] } = Astro.props;
---

<article class="surface-muted h-full rounded-[1.75rem] p-7 md:p-8">
  <h3 class="text-[1.9rem] leading-tight">{title}</h3>
  <p class="mt-4 text-[0.98rem] leading-7 text-[color:var(--color-muted)]">{text}</p>
  {items.length > 0 && (
    <ul class="mt-6 grid gap-3">
      {items.map((item) => (
        <li class="flex items-start gap-3 text-sm leading-6 text-[color:var(--color-ink)]">
          <span class="mt-2 h-1.5 w-6 rounded-full bg-[color:var(--color-accent)]"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}
</article>