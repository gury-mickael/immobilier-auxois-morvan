---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  class: customClass = '',
  target,
  rel
} = Astro.props;

const baseStyles =
  'inline-flex items-center justify-center gap-2 rounded-xl border text-sm font-semibold tracking-[0.01em] transition duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-bg)]';

const variantStyles = {
  primary:
    'border-[color:var(--color-accent)] bg-[color:var(--color-accent)] text-white hover:bg-[color:var(--color-accent-strong)] hover:border-[color:var(--color-accent-strong)]',
  secondary:
    'border-[color:var(--color-ink-strong)] bg-[color:var(--color-ink-strong)] text-white hover:bg-[#22343d]',
  outline:
    'border-[color:var(--color-border-strong)] bg-white text-[color:var(--color-ink-strong)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]',
  ghost: 'border-transparent bg-transparent text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]'
};

const sizeStyles = {
  sm: 'px-4 py-2.5',
  md: 'px-5 py-3',
  lg: 'px-6 py-3.5 text-[0.95rem]'
};

const widthClass = fullWidth ? 'w-full' : '';
const styleClass = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${widthClass} ${customClass}`;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class={styleClass}
  target={target}
  rel={rel}
  {...(href === undefined && { type: 'button' })}
>
  <slot />
</Tag>
