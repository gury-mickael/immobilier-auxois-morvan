---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'light';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  class: customClass = '',
  target,
  rel
} = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2 rounded-full font-medium tracking-tight transition-all duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-bg)]';

const variantStyles = {
  primary:
    'bg-[color:var(--color-ink-strong)] text-white hover:bg-[color:var(--color-accent-strong)]',
  secondary:
    'bg-[color:var(--color-accent)] text-white hover:bg-[color:var(--color-accent-strong)]',
  outline:
    'bg-transparent text-[color:var(--color-ink-strong)] ring-1 ring-inset ring-[color:var(--color-ink-strong)]/15 hover:ring-[color:var(--color-ink-strong)] hover:bg-[color:var(--color-ink-strong)] hover:text-white',
  ghost:
    'bg-transparent text-[color:var(--color-ink-strong)] hover:text-[color:var(--color-accent-strong)]',
  light:
    'bg-white text-[color:var(--color-ink-strong)] hover:bg-[color:var(--color-bg-soft)]'
};

const sizeStyles = {
  sm: 'px-4 py-2 text-[0.82rem]',
  md: 'px-5 py-2.5 text-[0.88rem]',
  lg: 'px-6 py-3.5 text-[0.92rem]'
};

const widthClass = fullWidth ? 'w-full' : '';
const styleClass = `${base} ${variantStyles[variant]} ${sizeStyles[size]} ${widthClass} ${customClass}`;

const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={styleClass} target={target} rel={rel} {...(href === undefined && { type: 'button' })}>
  <slot />
</Tag>
