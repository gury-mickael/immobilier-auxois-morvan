---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  class: customClass = ''
} = Astro.props;

const baseStyles = 'inline-block font-semibold rounded-lg transition-all duration-300 ease-in-out';

const variantStyles = {
  primary: 'bg-amber-600 text-white hover:bg-amber-700 shadow-md hover:shadow-lg',
  secondary: 'bg-slate-700 text-white hover:bg-slate-800 shadow-md hover:shadow-lg',
  outline: 'border-2 border-amber-600 text-amber-600 hover:bg-amber-50'
};

const sizeStyles = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};

const widthClass = fullWidth ? 'w-full' : '';
const styleClass = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${widthClass} ${customClass}`;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class={styleClass}
  {...(href === undefined && { type: 'button' })}
>
  <slot />
</Tag>
