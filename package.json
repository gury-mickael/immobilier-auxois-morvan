{
  "name": "immobilier-auxois-morvan",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev-php.mjs",
    "build": "node ./scripts/prepare-ovh-deploy.mjs",
    "hash-password": "node ./scripts/hash-password.mjs",
    "ovh:prepare": "node ./scripts/prepare-ovh-deploy.mjs",
    "ovh:deploy": "node ./scripts/deploy-ovh.mjs",
    "php:dev": "node ./scripts/dev-php.mjs",
    "php:stop": "docker compose down",
    "php:logs": "docker compose logs -f php",
    "php:db:reset": "docker compose down -v && rm -rf .local-state"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
